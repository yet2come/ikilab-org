---
interface Props {
  brand: string;
  brandHref?: string;
  navItems: { label: string; href: string }[];
  contactHref: string;
  mobileMenuVariant?: 'panel' | 'grid' | 'editorial' | 'slide' | 'minimal' | 'bottom-sheet';
}

const { brand, brandHref = "/", navItems, contactHref, mobileMenuVariant = 'panel' } = Astro.props;
const menuId = `mobile-menu-${mobileMenuVariant}`;
---
<header class="site-header" data-mobile-menu-variant={mobileMenuVariant}>
  <a href={brandHref} class="logo">
    <img src="/ikilab_logo_1500x500.svg" alt={brand} class="logo-image logo-image--30" />
  </a>
  <div class="nav-items">
    {navItems.map(item => (
      <a href={item.href}>{item.label}</a>
    ))}
    <div class="nav-spacer"></div>
  </div>
  <a href="/population/" class="header-pop" id="header-pop">
    <div class="header-pop-label">
      <span id="header-pop-year">2000年</span>
      <span>推計人口</span>
    </div>
    <div class="header-pop-display">
      <div class="header-pop-slot"><span id="hpd-0">3</span></div>
      <div class="header-pop-slot"><span id="hpd-1">4</span></div>
      <div class="header-pop-comma">,</div>
      <div class="header-pop-slot"><span id="hpd-2">4</span></div>
      <div class="header-pop-slot"><span id="hpd-3">1</span></div>
      <div class="header-pop-slot"><span id="hpd-4">7</span></div>
    </div>
    <div class="header-pop-meta">
      <span class="header-pop-delta" id="header-pop-delta"></span>
      <span class="header-pop-pct" id="header-pop-pct"></span>
    </div>
  </a>
  <a href={contactHref} class="nav-contact">Contact</a>
  <button class="mobile-menu-btn" aria-label="メニュー" aria-controls={menuId} aria-expanded="false" data-mobile-menu-toggle>
    <span></span><span></span><span></span>
  </button>
</header>
<div class={`mobile-menu mobile-menu--${mobileMenuVariant}`} id={menuId} hidden data-mobile-menu>
  <button class="mobile-menu-backdrop" aria-label="メニューを閉じる" data-mobile-menu-close></button>
  <div class="mobile-menu-surface">
    <div class="mobile-menu-head">
      <div>
        <div class="mobile-menu-eyebrow">Navigation</div>
        <div class="mobile-menu-brand">{brand}</div>
      </div>
      <button class="mobile-menu-close" aria-label="メニューを閉じる" data-mobile-menu-close>Close</button>
    </div>
    <nav class="mobile-menu-nav">
      {navItems.map((item, index) => (
        <a href={item.href} class="mobile-menu-link" data-mobile-menu-link>
          <span class="mobile-menu-index">{String(index + 1).padStart(2, '0')}</span>
          <span class="mobile-menu-label">{item.label}</span>
          <span class="mobile-menu-arrow">→</span>
        </a>
      ))}
      <a href="/population/" class="mobile-menu-link mobile-menu-link--population" data-mobile-menu-link>
        <span class="mobile-menu-index">P0</span>
        <span class="mobile-menu-label">Population</span>
        <span class="mobile-menu-arrow">→</span>
      </a>
      <a href={contactHref} class="mobile-menu-link mobile-menu-link--contact" data-mobile-menu-link>
        <span class="mobile-menu-index">C0</span>
        <span class="mobile-menu-label">Contact</span>
        <span class="mobile-menu-arrow">→</span>
      </a>
    </nav>
  </div>
</div>

<script>
  const popData = [
    { year: 2000, pop: 34417 },
    { year: 2005, pop: 31354 },
    { year: 2010, pop: 29377 },
    { year: 2015, pop: 27104 },
    { year: 2020, pop: 24948 },
    { year: 2024, pop: 23589 },
    { year: 2025, pop: 22644 },
    { year: 2030, pop: 20503 },
    { year: 2035, pop: 18454 },
    { year: 2040, pop: 16475 },
    { year: 2045, pop: 14622 },
    { year: 2050, pop: 13199 },
  ];

  function lerpPop(year: number): number {
    if (year <= popData[0].year) return popData[0].pop;
    if (year >= popData[popData.length - 1].year) return popData[popData.length - 1].pop;
    for (let i = 0; i < popData.length - 1; i++) {
      if (year >= popData[i].year && year <= popData[i + 1].year) {
        const t = (year - popData[i].year) / (popData[i + 1].year - popData[i].year);
        return Math.round(popData[i].pop + t * (popData[i + 1].pop - popData[i].pop));
      }
    }
    return popData[0].pop;
  }

  function toJapaneseEra(year: number): string {
    if (year >= 2019) return `令和${year - 2018}年`;
    if (year >= 1989) return `平成${year - 1988}年`;
    return `昭和${year - 1925}年`;
  }

  function initHeaderPop() {
    const yearEl = document.getElementById('header-pop-year');
    const digitEls = [0,1,2,3,4].map(i => document.getElementById(`hpd-${i}`));
    const deltaEl = document.getElementById('header-pop-delta');
    const pctEl = document.getElementById('header-pop-pct');
    if (!yearEl || digitEls.some(e => !e) || !deltaEl || !pctEl) return;

    const basePop = popData[0].pop;
    const startYear = popData[0].year;
    const endYear = popData[popData.length - 1].year;

    function onScroll() {
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docH > 0 ? Math.max(0, Math.min(1, window.scrollY / docH)) : 0;
      const currentYear = startYear + progress * (endYear - startYear);
      const roundedYear = Math.round(currentYear);
      const currentPop = lerpPop(currentYear);
      const diff = currentPop - basePop;
      const pct = ((diff / basePop) * 100).toFixed(1);

      yearEl.textContent = `${roundedYear}年`;

      const digits = String(currentPop).padStart(5, '0');
      digitEls.forEach((el, i) => { if (el) el.textContent = digits[i]; });

      if (diff < 0) {
        deltaEl.textContent = `${diff.toLocaleString('en-US')}人`;
        pctEl.textContent = `${pct}%`;
      } else {
        deltaEl.textContent = '';
        pctEl.textContent = '';
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  function initMobileMenu() {
    const toggle = document.querySelector<HTMLElement>('[data-mobile-menu-toggle]');
    const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
    if (!toggle || !menu) return;

    const closeButtons = menu.querySelectorAll<HTMLElement>('[data-mobile-menu-close]');
    const links = menu.querySelectorAll<HTMLElement>('[data-mobile-menu-link]');

    function openMenu() {
      menu.hidden = false;
      requestAnimationFrame(() => {
        menu.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.classList.add('mobile-menu-open');
      });
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('mobile-menu-open');
      window.setTimeout(() => {
        if (!menu.classList.contains('is-open')) {
          menu.hidden = true;
        }
      }, 220);
    }

    toggle.addEventListener('click', () => {
      if (menu.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    closeButtons.forEach((button) => button.addEventListener('click', closeMenu));
    links.forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && menu.classList.contains('is-open')) {
        closeMenu();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initHeaderPop();
    initMobileMenu();
  });
</script>
