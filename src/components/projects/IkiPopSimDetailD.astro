---
const d = {
  title: '壱岐市 人口シミュレーション',
  status: 'Development',
  en: 'Population simulation for policy design.',
  lead: '社人研の推計データをベースに、壱岐市の将来人口動態をシミュレーション。施策効果の可視化、因果ループ分析、感度分析などを通じて、人口問題へのアプローチを構造的に探るプロジェクト。',
  externalLabel: 'シミュレーターを見る（v1）',
  externalHref: 'https://sim.ikilab.org/',

  experiment: {
    what: '日立評論2019年3月号「社会駆動型AI」の3ステージ手法を参考に、壱岐市の2024〜2050年の社会指標をシミュレートするWebアプリを構築。人口、出生率、高齢化率、転入超過数、観光客数、漁業生産額、農業産出額、テレワーク移住数、財政健全度、公共交通充足率、空き家率の11指標を、7つの政策レバー（移住支援・観光振興・漁業活性化・農業活性化・テレワーク推進・子育て支援・交通インフラ）で操作し、因果連鎖モデルで将来を可視化する。4つのプリセットシナリオ（子育て島宣言・デジタルアイランド・観光立島・縮小均衡）も用意。',
    howDifferent: '行政の人口ビジョンは5年ごとの静的な推計が中心で、施策と人口の因果関係が見えにくい。このシミュレーターは7つの政策レバーをリアルタイムに操作し、11指標への波及効果を即座に確認できる。指標間の因果連鎖（例：子育て支援→出生率向上→人口維持→財政改善）をモデル化し、単一施策ではなく政策パッケージとしての効果を検証できる点が異なる。',
  },

  phases: [
    { key: 'research', label: 'データ整理' },
    { key: 'v1', label: 'v1（ベースライン）' },
    { key: 'v2', label: 'v2（シナリオ拡張）' },
    { key: 'application', label: '活用・対話' },
  ],
  currentPhaseKey: 'v2',
  currentFocus: [
    '因果連鎖モデルの精度向上（指標間の依存関係の調整）',
    '100mメッシュ人口マップと指標シミュレーションの連携',
    '実績データの充実（公共交通・空き家率の正式統計への差し替え）',
    '対話の場（壱岐オープンダイアログ等）での活用実験',
    '財政健全度の計算ロジック改善（財政力指数・経常収支比率の正式算定）',
  ],

  findings: {
    learnings: [
      '11指標×7政策レバーの因果連鎖モデルにより、単一施策ではなく政策パッケージとしての効果を可視化できるようになった。',
      '4つのプリセットシナリオ（子育て島宣言・デジタルアイランド・観光立島・縮小均衡）を用意したことで、「どの方向に舵を切るか」の議論の起点ができた。',
      '100mメッシュの人口マップを実装し、島内の人口分布の偏りと空間的な課題を直感的に示せるようになった。',
      '2032〜2034年が「都市集中型」と「地方分散型」の分岐点となることが、日立評論の知見と壱岐のデータの両面から示唆された。',
    ],
    challenges: [
      '公共交通充足率・空き家率の実績データが推計値に留まっており、モデルの精度に限界がある。',
      '財政健全度の換算ロジックが暫定的で、総務省の正式指標（財政力指数・経常収支比率）への整合が必要。',
      '政策レバーの「50」が具体的に何を意味するかの定義が曖昧で、行政担当者との共通言語化が課題。',
      '大字（集落）レベルへのブレイクダウンが未実装で、地区ごとの施策検討に使えない。',
    ],
    openQuestions: [
      'シミュレーション結果を、どの層（行政、議会、住民、事業者）にどう届けるべきか',
      '「何人増えれば持続可能か」という問いに対して、シミュレーションはどこまで答えられるか',
      '他のIKILABプロジェクト（ワークデザイン構想、モビリティ実証）との連動でシナリオをどう具体化するか',
      '悲観シナリオを示すことが地域に与える心理的影響をどう扱うか',
    ],
  },

  next: {
    plans: [
      '大字（集落）レベルへのブレイクダウンの実装',
      '財政健全度の計算ロジックを総務省の正式指標に整合',
      '対話イベント（壱岐オープンダイアログ等）での活用実験',
      'シミュレーション結果キャッシュのSupabase Edge Functions移行',
      '他プロジェクト（ワークデザイン構想、モビリティ実証）のシナリオとの統合',
    ],
    scalability: '社人研の推計データは全国の自治体で利用可能であり、同じフレームワークを他の過疎地域や離島に展開できる。シミュレーターの構造自体は汎用的で、パラメータとデータを差し替えれば他地域版を構築可能。',
  },

  involvement: [
    {
      who: 'company',
      label: '人口データ分析・政策シミュレーション',
      body: '自治体向けのデータ分析や政策立案支援に関心のある企業、シンクタンクの方へ。',
      examples: ['シミュレーションモデルの精度向上', '政策効果の定量評価手法の共同開発', '他自治体への展開支援'],
    },
    {
      who: 'researcher',
      label: '人口動態・地域政策の研究',
      body: '人口減少、地方創生、コーホート分析、システムダイナミクスに関心のある研究者の方へ。',
      examples: ['因果モデルの学術的検証', 'パラメータ設定の妥当性分析', '施策効果の実証研究'],
    },
    {
      who: 'supporter',
      label: '地域での対話・活用',
      body: '壱岐の将来を考える対話の場で、シミュレーション結果を活用したい方。行政・議会・地域団体の方。',
      examples: ['対話イベントでの活用', '地域計画策定への参考利用', '住民説明会での可視化ツールとして'],
    },
    {
      who: 'individual',
      label: '開発・データ整備への貢献',
      body: 'データ可視化、フロントエンド開発、統計分析のスキルを持つ方。',
      examples: ['シミュレーションUIの改善', 'データパイプラインの構築', 'グラフ・チャートの表現改善'],
    },
  ],

  projectInfo: {
    milestones: [
      { date: '2026.03', body: 'Vite + React プロジェクトを立ち上げ。Supabaseで指標マスタ・実績データ・シナリオのDB設計。' },
      { date: '2026.03', body: '人口推計シミュレーター（v1）を構築。社人研ベースライン + シナリオ比較 + 因果ループ図 + 感度分析を実装し sim.ikilab.org として公開。' },
      { date: '2026.03', body: '100mメッシュ人口マップ機能を追加。農業・漁業の実績データを公式統計で較正。' },
      { date: '2026.04', body: '4つのプリセットシナリオ（子育て島宣言・デジタルアイランド・観光立島・縮小均衡）を追加。' },
      { date: '2026.04', body: '因果連鎖モデルへリファクタリング。未来シナリオシミュレーター（v2）を sim2.ikilab.org として公開。' },
    ],
    team: [
      { name: '（Members Only）', role: '企画・開発' },
    ],
    relatedProjects: [
      { label: '壱岐島ワークデザイン構想', href: '/projects/rito-job-matching' },
      { label: '壱岐オープンダイアログ', href: '#' },
    ],
    links: [
      { label: 'シミュレーター v1', href: 'https://sim.ikilab.org/' },
      { label: 'シミュレーター v2', href: 'https://sim2.ikilab.org/' },
      { label: '参考: 日立評論「社会駆動型AI」', href: 'https://www.hitachihyoron.com/jp/archive/2010s/2019/03/05c04/index.html' },
    ],
  },
};

const sections = [
  { id: 'background', label: '背景' },
  { id: 'experiment', label: '実験内容' },
  { id: 'findings', label: '知見' },
  { id: 'involvement', label: '関わり方' },
  { id: 'info', label: 'プロジェクト情報' },
];

const whoLabels: Record<string, string> = {
  company: '企業',
  individual: '個人',
  researcher: '研究者',
  supporter: 'サポーター',
};
---
<section class="pdd-hero">
  <div class="pdd-hero-inner">
    <span class="pdd-badge">{d.status}</span>
    <h1>{d.title}</h1>
    <div class="pdd-en">{d.en}</div>
    <p>{d.lead}</p>
    <div class="pdd-hero-actions">
      <a href="/projects" class="btn-brutal btn-ghost">一覧に戻る</a>
      {d.externalHref && <a href={d.externalHref} target="_blank" rel="noreferrer" class="btn-brutal btn-fill">{d.externalLabel}</a>}
    </div>
  </div>
</section>

<nav class="pdd-nav">
  {sections.map(s => <a href={`#${s.id}`} class="pdd-nav-link">{s.label}</a>)}
</nav>

<div class="pdd-bar"><span>01</span> BACKGROUND</div>
<section id="background" class="pdd-section">
  <div class="pdd-col">
    <h3>どんな問題か</h3>
    <p>壱岐市の人口は2020年時点で24,948人。社人研の推計では2050年に13,199人まで減少し、65歳以上の比率は50%に達します。人口減少は雇用、医療、教育、交通、産業のあらゆる領域に波及しますが、その構造と影響の全体像を直感的に把握する手段が限られています。</p>
  </div>
  <div class="pdd-col">
    <h3>なぜ壱岐でやるのか</h3>
    <p>離島は人口問題の影響がより先鋭的に現れるフィールドです。若年層の島外流出、Uターンの停滞、出生率の変化——これらが閉じた系の中で連鎖するため、構造がシミュレーションしやすい。壱岐で得た知見は、同規模の過疎地域にも応用可能です。</p>
  </div>
  <div class="pdd-col">
    <h3>なぜ今やるのか</h3>
    <p>壱岐市の人口減少は加速期に入っています。2020年代後半は施策の効果が「まだ間に合う」最後の窓口とされており、今この段階でシミュレーションに基づく議論を始めることに意味があります。行政の次期人口ビジョン策定にも接続できるタイミングです。</p>
  </div>
</section>

<div class="pdd-bar"><span>02</span> EXPERIMENT</div>
<section id="experiment" class="pdd-section">
  <div class="pdd-col">
    <h3>何をどう試しているか</h3>
    <p>{d.experiment.what}</p>
  </div>
  <div class="pdd-col">
    <h3>従来と何が違うか</h3>
    <p>{d.experiment.howDifferent}</p>
  </div>
</section>

<div class="pdd-bar pdd-bar--alt"><span>03</span> STATUS</div>
<section class="pdd-section pdd-section--alt">
  <div class="pdd-stepper">
    {d.phases.map((phase, i) => (
      <div class={`pdd-step ${phase.key === d.currentPhaseKey ? 'pdd-step--active' : ''}`}>
        <div class="pdd-step-indicator">
          <div class="pdd-step-dot"></div>
          {i < d.phases.length - 1 && <div class="pdd-step-line"></div>}
        </div>
        <div class="pdd-step-label">{phase.label}</div>
      </div>
    ))}
  </div>
  <h3>現在の取り組み</h3>
  <ul class="pdd-focus-list">
    {d.currentFocus.map(item => <li>{item}</li>)}
  </ul>
</section>

<div class="pdd-bar"><span>04</span> FINDINGS</div>
<section id="findings" class="pdd-section">
  <div class="pdd-findings-group">
    <h3>見えてきたこと</h3>
    {d.findings.learnings.map(item => (
      <div class="pdd-finding-row pdd-finding--learning"><span>○</span><p>{item}</p></div>
    ))}
  </div>
  <div class="pdd-findings-group">
    <h3>課題として残っていること</h3>
    {d.findings.challenges.map(item => (
      <div class="pdd-finding-row pdd-finding--challenge"><span>△</span><p>{item}</p></div>
    ))}
  </div>
  <div class="pdd-findings-group">
    <h3>まだ答えの出ていない問い</h3>
    {d.findings.openQuestions.map(item => (
      <div class="pdd-finding-row pdd-finding--question"><span>?</span><p>{item}</p></div>
    ))}
  </div>
</section>

<div class="pdd-bar pdd-bar--alt"><span>05</span> NEXT</div>
<section class="pdd-section pdd-section--alt">
  <h3>次にやること</h3>
  <ul class="pdd-focus-list">
    {d.next.plans.map(item => <li>{item}</li>)}
  </ul>
  <h3>再現性の見立て</h3>
  <p class="pdd-scalability">{d.next.scalability}</p>
</section>

<div class="pdd-bar"><span>06</span> INVOLVEMENT</div>
<section id="involvement" class="pdd-section">
  <div class="pdd-involve-grid">
    {d.involvement.map(inv => (
      <div class="pdd-involve-card">
        <div class="pdd-involve-who">{whoLabels[inv.who] || inv.who}</div>
        <h3>{inv.label}</h3>
        <p>{inv.body}</p>
        {inv.examples && inv.examples.length > 0 && (
          <ul class="pdd-involve-examples">
            {inv.examples.map(ex => <li>{ex}</li>)}
          </ul>
        )}
      </div>
    ))}
  </div>
  <div class="pdd-mid-cta">
    <p>人口シミュレーションに関わりたい方はお気軽にご連絡ください。</p>
    <a href="/contact" class="btn-brutal btn-fill">お問い合わせ →</a>
  </div>
</section>

<div class="pdd-bar pdd-bar--alt"><span>07</span> PROJECT INFO</div>
<section id="info" class="pdd-section pdd-section--alt">
  <h3>タイムライン</h3>
  <div class="pdd-milestones">
    {d.projectInfo.milestones.map(ms => (
      <div class="pdd-milestone">
        <span class="pdd-milestone-date">{ms.date}</span>
        <div><p>{ms.body}</p></div>
      </div>
    ))}
  </div>

  <div class="pdd-info-grid">
    <div>
      <h4>体制</h4>
      {d.projectInfo.team.map(member => (
        <div class="pdd-team-row">
          <span class="pdd-team-role">{member.role}</span>
          <span>{member.name}</span>
        </div>
      ))}
    </div>
    <div>
      <h4>関連プロジェクト</h4>
      {d.projectInfo.relatedProjects.map(rp => (
        <a href={rp.href} class="pdd-info-link">{rp.label} →</a>
      ))}
    </div>
    <div>
      <h4>関連リンク</h4>
      {d.projectInfo.links.map(link => (
        <a href={link.href} target="_blank" rel="noreferrer" class="pdd-info-link">{link.label} →</a>
      ))}
    </div>
  </div>
</section>

<section class="pdd-final-cta">
  <div class="pdd-final-cta-inner">
    <div class="pdd-cta-kicker">Connect</div>
    <h2>このプロジェクトに関心がある方へ</h2>
    <p>人口シミュレーション、地域政策のデータ分析、過疎地域の将来設計に関心がある方はご連絡ください。</p>
    <a href="/contact" class="btn-brutal btn-fill" style="background:var(--red);border-color:var(--red);">お問い合わせ →</a>
  </div>
</section>
