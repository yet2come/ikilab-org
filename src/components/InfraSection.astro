---
interface TableRow {
  label: string;
  value: string;
}

interface Props {
  name: string;
  nameEn: string;
  photoPlaceholder: string;
  table: TableRow[];
  detailHref: string;
}

const { name, nameEn, photoPlaceholder, table, detailHref } = Astro.props;
---
<div class="infra-layout reveal">
  <div class="infra-photo">
    <iframe
      src="https://www.google.com/maps?q=%E3%82%AF%E3%83%AD%E3%82%B9%E3%83%9D%E3%83%BC%E3%83%88%E6%AD%A6%E7%94%9F%E6%B0%B4&output=embed"
      width="100%"
      height="100%"
      style="border:0; display:block;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="CROSSPORT MSZ - Google Map"
    ></iframe>
  </div>
  <div class="infra-details">
    <div class="infra-name">
      <img src="/ikilab_logo_1500x500.svg" alt={name} class="infra-logo" />
    </div>
    <table class="infra-table">
      {table.map(row => (
        <tr>
          <td>{row.label}</td>
          <td set:html={row.value.replace(/\n/g, '<br>')} />
        </tr>
      ))}
    </table>
    <a href={detailHref} class="btn-brutal btn-fill" style="display:inline-flex">施設の詳細 →</a>
  </div>
</div>
