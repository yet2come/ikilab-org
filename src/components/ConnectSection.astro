---
interface ConnectCard {
  sym: string;
  title: string;
  body: string;
  cta: string;
}

interface Props {
  cards: ConnectCard[];
}

const { cards } = Astro.props;
---
<div class="connect-grid">
  {cards.map(card => (
    <div class="connect-card">
      <span class="connect-card-sym">{card.sym}</span>
      <h3>{card.title}</h3>
      <p>{card.body}</p>
      <span class="connect-card-cta">{card.cta} <span>→</span></span>
    </div>
  ))}
</div>
