---
interface HeroAction {
  label: string;
  href: string;
  style: "fill" | "ghost";
}

interface Props {
  tag: string;
  titleHtml: string;
  en: string;
  bodyHtml: string;
  actions: HeroAction[];
  date: string;
  coord: string;
  imagePlaceholder: string;
}

const { tag, titleHtml, en, bodyHtml, actions, date, coord, imagePlaceholder } = Astro.props;

const odometerStart = 23589;
const odometerEnd = 23013;

function buildCountdownFrames(start: number, end: number) {
  const frames: string[] = [];

  for (let value = start; value >= end; value--) {
    frames.push(String(value).padStart(5, '0'));
  }

  return frames;
}

const odometerFrames = buildCountdownFrames(odometerStart, odometerEnd);
const odometerSequences = Array.from({ length: 5 }, (_, index) =>
  odometerFrames.map(frame => Number(frame[index]))
);
---
<section class="hero">
  <div class="hero-left">
    <div class="hero-tag">{tag}</div>
    <h1 set:html={titleHtml} />
    <div class="hero-en">{en}</div>
    <p class="hero-body" set:html={bodyHtml} />
    <div class="hero-actions">
      {actions.map(action => (
        <a href={action.href} class={`btn-brutal btn-${action.style}`}>{action.label}</a>
      ))}
    </div>
  </div>
  <div class="hero-right hero-right--odometer">
    <a href="/pop2/" class="hero-odometer-link" id="hero-odometer">
      <div class="hero-odometer-label">壱岐市 推計人口</div>
      <div class="hero-odometer-display">
        {odometerSequences.slice(0, 2).map(sequence => (
          <div class="hero-odometer-slot">
            <div
              class="hero-odometer-strip"
              data-steps={Math.max(sequence.length - 1, 0)}
            >
              {sequence.map(digit => <span>{digit}</span>)}
            </div>
          </div>
        ))}
        <div class="hero-odometer-comma">,</div>
        {odometerSequences.slice(2).map(sequence => (
          <div class="hero-odometer-slot">
            <div
              class="hero-odometer-strip"
              data-steps={Math.max(sequence.length - 1, 0)}
            >
              {sequence.map(digit => <span>{digit}</span>)}
            </div>
          </div>
        ))}
      </div>
      <div class="hero-odometer-unit">人</div>
      <div class="hero-odometer-years">
        <span>2024.01</span>
        <span class="hero-odometer-arrow">→</span>
        <span id="hero-odometer-current-date">2024.01</span>
      </div>
      <div class="hero-odometer-diff" id="hero-odometer-diff">−576 人（1年間）</div>
      <div class="hero-odometer-cta">詳しく見る →</div>
    </a>
    <div class="hero-date">{date}</div>
    <div class="hero-coord">{coord}</div>
  </div>
</section>

<style>
  .hero-right--odometer {
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: appear 0.8s 0.3s forwards;
  }

  .hero-odometer-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    padding: 40px 24px;
    transition: transform 0.2s;
  }

  .hero-odometer-link:hover {
    transform: scale(1.02);
  }

  .hero-odometer-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 20px;
  }

  .hero-odometer-display {
    display: inline-flex;
    align-items: center;
    background: var(--black);
    padding: 10px 6px;
    border-radius: 8px;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.4);
  }

  .hero-odometer-slot {
    width: clamp(40px, 5vw, 56px);
    height: clamp(60px, 7.5vw, 84px);
    overflow: hidden;
    position: relative;
    background: var(--dark);
    margin: 0 2px;
    border-radius: 4px;
    border: 1px solid #333;
  }

  .hero-odometer-strip {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }

  .hero-odometer-strip span {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: clamp(40px, 5vw, 56px);
    height: clamp(60px, 7.5vw, 84px);
    font-family: var(--font-mono);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
    font-kerning: none;
    color: #e0e0e0;
    text-shadow: 0 0 10px rgba(255,255,255,0.1);
  }

  .hero-odometer-slot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255,255,255,0.08);
    pointer-events: none;
  }

  .hero-odometer-slot::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, transparent 30%, transparent 70%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-odometer-comma {
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
    color: #666;
    margin: 0 2px;
    align-self: flex-end;
    padding-bottom: 6px;
  }

  .hero-odometer-unit {
    font-family: var(--font-jp);
    font-size: 18px;
    font-weight: 700;
    color: var(--black);
    margin-top: 14px;
  }

  .hero-odometer-years {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 10px;
    letter-spacing: 0.05em;
  }

  .hero-odometer-arrow {
    margin: 0 6px;
    color: var(--red);
  }

  .hero-odometer-diff {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--red);
    margin-top: 6px;
    letter-spacing: 0.02em;
    opacity: 0;
    transition: opacity 0.5s 15.8s;
  }

  .hero-odometer-diff.visible {
    opacity: 1;
  }

  .hero-odometer-cta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--gray-500);
    margin-top: 16px;
    padding: 6px 16px;
    border: 1px solid var(--gray-300);
    transition: all 0.2s;
  }

  .hero-odometer-link:hover .hero-odometer-cta {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  @media (max-width: 900px) {
    .hero-odometer-link {
      padding: 32px 16px;
    }
  }
</style>

<script>
  function initHeroOdometer() {
    const container = document.getElementById('hero-odometer');
    const currentDate = document.getElementById('hero-odometer-current-date');
    if (!container) return;

    const slots = container.querySelectorAll('.hero-odometer-slot');
    const slotList = Array.from(slots);

    // Set initial position
    slots.forEach((slot) => {
      const strip = slot.querySelector('.hero-odometer-strip') as HTMLElement;
      strip.style.transition = 'none';
      strip.style.transform = 'translateY(0)';
    });

    // Animate on viewport entry
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            const duration = 15000;
            const totalMonths = 12;
            const animationStart = performance.now();
            let lastMonth = -1;

            slotList.forEach((slot, index) => {
              const strip = slot.querySelector('.hero-odometer-strip') as HTMLElement;
              const digit = strip.firstElementChild as HTMLElement | null;
              const h = digit?.getBoundingClientRect().height || slot.clientHeight || 84;
              const steps = Number(strip.dataset.steps || Math.max(strip.children.length - 1, 0));
              if (steps === 0) return;

              const distance = steps * h;
              const leadSteps = Math.max(1, Math.round(steps * 0.15));
              const tailSteps = Math.max(1, Math.round(steps * 0.15));
              const middleSteps = Math.max(1, steps - leadSteps - tailSteps);
              const normalizedLeadSteps = steps - middleSteps - tailSteps;
              const leadDistance = normalizedLeadSteps * h;
              const middleDistance = middleSteps * h;

              strip.animate([
                { transform: 'translateY(0)', offset: 0, easing: `steps(${normalizedLeadSteps}, end)` },
                { transform: `translateY(-${leadDistance}px)`, offset: 0.25, easing: `steps(${middleSteps}, end)` },
                { transform: `translateY(-${leadDistance + middleDistance}px)`, offset: 0.75, easing: `steps(${tailSteps}, end)` },
                { transform: `translateY(-${distance}px)`, offset: 1 },
              ], {
                duration,
                delay: 0,
                fill: 'forwards',
              });
              strip.style.transform = `translateY(-${distance}px)`;
            });

            function syncDate(now: number) {
              if (!currentDate) return;

              const progress = Math.min((now - animationStart) / duration, 1);
              const monthIndex = Math.round(progress * totalMonths);

              if (monthIndex !== lastMonth) {
                const year = 2024 + Math.floor(monthIndex / 12);
                const month = (monthIndex % 12) + 1;
                currentDate.textContent = `${year}.${String(month).padStart(2, '0')}`;
                lastMonth = monthIndex;
              }

              if (progress < 1) {
                requestAnimationFrame(syncDate);
                return;
              }

              document.getElementById('hero-odometer-diff')?.classList.add('visible');
            }

            requestAnimationFrame(syncDate);
          }, 800);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(container);
  }

  document.addEventListener('DOMContentLoaded', initHeroOdometer);
</script>
