---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { patternA as data } from '../../data/pattern-a';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { slug: 'en' }, props: { page: { title: 'English', titleJa: 'English', description: 'IKILAB in English.' } } },
  ];
}

const { page } = Astro.props;
---
<Base title={`${page.titleJa} — IKILAB`} description={page.description}>
  <Header brand={data.brand} brandHref="/pattern-a/" navItems={data.navItems} contactHref={data.contactHref} />

  <div class="subpage-hero">
    <h1>{page.titleJa}</h1>
    <div class="hero-en">{page.title}</div>
    <p>{page.description}</p>
  </div>

  <div class="subpage-content">
    <h2>Coming Soon</h2>
    <p>This page is under construction. Please visit the top page.</p>
    <a href="/pattern-a/" class="btn-brutal btn-fill" style="display:inline-flex">Back to Top →</a>
  </div>

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
