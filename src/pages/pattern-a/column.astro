---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionBar from '../../components/SectionBar.astro';
import { patternA as data } from '../../data/pattern-a';
import '../../styles/global.css';

const articles = [
  { date: "2024.12", tag: "Report", title: "IKI ZINE FES 2024 開催レポート", body: "島内外から120人が参加。手づくり冊子を通じた文化発信の一日を振り返る。" },
  { date: "2024.10", tag: "Essay", title: "離島で実験するということ", body: "IKILABが壱岐島で活動を始めて2年。見えてきた「離島実験」の可能性と課題。" },
  { date: "2024.08", tag: "Report", title: "電動トゥクトゥク実証 中間報告", body: "夏季観光シーズンの実証データから見えた、離島二次交通の可能性。" },
  { date: "2024.06", tag: "Interview", title: "島の事業者に聞く：IKILABとの協働", body: "地元の宿泊施設、飲食店、農家。IKILABと関わることで何が変わったか。" },
  { date: "2024.04", tag: "Essay", title: "ワーケーションの先にあるもの", body: "「働く場所の自由」から「暮らし方の実験」へ。島滞在が変える仕事観。" },
  { date: "2024.02", tag: "Report", title: "しまチャレ2024 参加記録", body: "長崎県主催の島しょビジネスチャレンジ。IKILAB特別賞の選定と、出会った挑戦者たち。" },
];
---
<Base title="コラム — IKILAB" description="島からのレポートとコラム。IKILABの活動記録。">
  <Header brand={data.brand} brandHref="/pattern-a/" navItems={data.navItems} contactHref={data.contactHref} />

  <div class="subpage-hero">
    <h1>コラム</h1>
    <div class="hero-en">Column</div>
    <p>島からのレポート、エッセイ、インタビュー。IKILABの実験と日常を記録します。</p>
  </div>

  <SectionBar num="01" title="Articles — 記事一覧" />
  <div class="proof-cases reveal">
    {articles.map(article => (
      <div class="case-row">
        <div class="case-img">
          <span class="case-img-ph">{article.date}</span>
        </div>
        <div class="case-content">
          <div class="case-tag">{article.tag}</div>
          <h4>{article.title}</h4>
          <p>{article.body}</p>
        </div>
        <div class="case-arrow">→</div>
      </div>
    ))}
  </div>

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
