---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionBar from '../../components/SectionBar.astro';
import ExperimentsGrid from '../../components/ExperimentsGrid.astro';
import { patternA as data } from '../../data/pattern-a';
import '../../styles/global.css';
---
<Base title="実験一覧 — IKILAB" description="IKILABが現在進行中の実験プロジェクト一覧。">
  <Header brand={data.brand} brandHref="/pattern-a/" navItems={data.navItems} contactHref={data.contactHref} />

  <div class="subpage-hero">
    <h1>進行中の実験</h1>
    <div class="hero-en">Experiments</div>
    <p>IKILABが壱岐島で取り組んでいる実験プロジェクトの一覧です。各実験は、島の課題を構造的に解くためのアプローチです。</p>
  </div>

  <SectionBar num="01" title="Active — 進行中" />
  <ExperimentsGrid items={data.experiments.items.filter(i => i.status === 'active')} />

  <SectionBar num="02" title="Planned — 計画中" />
  <ExperimentsGrid items={data.experiments.items.filter(i => i.status === 'planned')} />

  <div class="subpage-content">
    <h2>実験の進め方</h2>
    <p>
      IKILABの実験は、以下のサイクルで進みます。
    </p>
    <p>
      <strong>1. 課題の発見</strong> — 島の日常から課題を見つけ、構造化する。<br>
      <strong>2. 仮説の設計</strong> — 課題に対するアプローチを仮説として設計する。<br>
      <strong>3. 小さく試す</strong> — 最小限の規模で実装し、フィードバックを得る。<br>
      <strong>4. 検証と改善</strong> — 結果を分析し、次のサイクルにつなげる。
    </p>
    <p>
      新しい実験の提案や、既存の実験への参加に興味がある方は、お気軽にお問い合わせください。
    </p>
    <a href="/pattern-a/contact" class="btn-brutal btn-fill" style="display:inline-flex">実験に参加する →</a>
  </div>

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
