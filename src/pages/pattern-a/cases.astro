---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionBar from '../../components/SectionBar.astro';
import ProofSection from '../../components/ProofSection.astro';
import { patternA as data } from '../../data/pattern-a';
import '../../styles/global.css';
---
<Base title="事例 — IKILAB" description="IKILABのこれまでの実装事例。">
  <Header brand={data.brand} brandHref="/pattern-a/" navItems={data.navItems} contactHref={data.contactHref} />

  <div class="subpage-hero">
    <h1>実装事例</h1>
    <div class="hero-en">Cases</div>
    <p>IKILABがこれまでに取り組んできたプロジェクトの実績と成果。</p>
  </div>

  <SectionBar num="01" title="Numbers — 数字で見るIKILAB" />
  <ProofSection stats={data.proof.stats} cases={data.proof.cases} />

  <SectionBar num="02" title="More Cases — その他の事例" />
  <div class="proof-cases reveal">
    <div class="case-row">
      <div class="case-img"><span class="case-img-ph">PHOTO</span></div>
      <div class="case-content">
        <div class="case-tag">Workation / Remote Work</div>
        <h4>ワーケーションプログラム 2023-2024</h4>
        <p>延べ80名以上のリモートワーカーを受入。平均滞在日数7日間。参加者の30%がリピート利用。</p>
      </div>
      <div class="case-arrow">→</div>
    </div>
    <div class="case-row">
      <div class="case-img"><span class="case-img-ph">PHOTO</span></div>
      <div class="case-content">
        <div class="case-tag">Content / Media</div>
        <h4>壱岐ZINE制作プロジェクト</h4>
        <p>島の暮らし・文化・食をテーマにした自主制作冊子。累計3号発行、配布部数1,500部超。</p>
      </div>
      <div class="case-arrow">→</div>
    </div>
    <div class="case-row">
      <div class="case-img"><span class="case-img-ph">PHOTO</span></div>
      <div class="case-content">
        <div class="case-tag">Community / Local</div>
        <h4>壱岐カレンダー運用開始</h4>
        <p>島内のイベント・行事を一元管理するプラットフォーム。月間アクティブユーザー500人超。</p>
      </div>
      <div class="case-arrow">→</div>
    </div>
  </div>

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
