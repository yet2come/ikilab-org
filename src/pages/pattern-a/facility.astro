---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionBar from '../../components/SectionBar.astro';
import InfraSection from '../../components/InfraSection.astro';
import { patternA as data } from '../../data/pattern-a';
import '../../styles/global.css';
---
<Base title="施設紹介 — IKILAB" description="IKILAB武生水の施設情報。コワーキング、会議室、イベントホール。">
  <Header brand={data.brand} brandHref="/pattern-a/" navItems={data.navItems} contactHref={data.contactHref} />

  <div class="subpage-hero">
    <h1>IKILAB武生水</h1>
    <div class="hero-en">Facility</div>
    <p>壱岐島・郷ノ浦にある、島内外を接続する実験装置の物理的拠点。コワーキング、会議室、イベントスペースを備えています。</p>
  </div>

  <SectionBar num="01" title="Overview — 施設概要" />
  <InfraSection
    name={data.infra.name}
    nameEn={data.infra.nameEn}
    photoPlaceholder={data.infra.photoPlaceholder}
    table={data.infra.table}
    detailHref="/pattern-a/contact"
  />

  <SectionBar num="02" title="Space — スペース一覧" />
  <div class="why reveal">
    <div class="why-item">
      <div class="why-item-idx">1</div>
      <h3>コワーキングスペース</h3>
      <p>高速Wi-Fi、電源完備のオープンスペース。ドロップイン利用可能。集中作業にもミーティングにも対応。</p>
    </div>
    <div class="why-item">
      <div class="why-item-idx">2</div>
      <h3>会議室</h3>
      <p>最大10名収容の個室会議室。プロジェクター、ホワイトボード完備。オンライン会議にも対応。</p>
    </div>
    <div class="why-item">
      <div class="why-item-idx">3</div>
      <h3>イベントホール</h3>
      <p>最大50名収容のイベントスペース。セミナー、ワークショップ、展示会、上映会など多用途に対応。</p>
    </div>
  </div>

  <SectionBar num="03" title="Pricing — 料金" />
  <div class="subpage-content">
    <table class="infra-table">
      <tr><td>Drop-in</td><td>1日 1,000円（税込）</td></tr>
      <tr><td>Monthly</td><td>月額 10,000円（税込）</td></tr>
      <tr><td>Meeting</td><td>1時間 2,000円（税込）</td></tr>
      <tr><td>Event</td><td>半日 10,000円 / 全日 18,000円（税込）</td></tr>
    </table>
    <p style="margin-top:24px;">料金は変更になる場合があります。詳しくはお問い合わせください。</p>
    <a href="/pattern-a/contact" class="btn-brutal btn-fill" style="display:inline-flex; margin-top:24px;">お問い合わせ →</a>
  </div>

  <SectionBar num="04" title="Access — アクセス" />
  <div class="subpage-content">
    <h2>壱岐島へのアクセス</h2>
    <p>
      <strong>博多港から</strong><br>
      高速船（ジェットフォイル）で約1時間 / フェリーで約2時間20分
    </p>
    <p>
      <strong>長崎空港から</strong><br>
      壱岐空港までORC（オリエンタルエアブリッジ）で約30分
    </p>
    <p>
      <strong>施設まで</strong><br>
      郷ノ浦港から徒歩12分 / 壱岐空港から車で約15分
    </p>
  </div>

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
