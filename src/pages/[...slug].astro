---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { cases } from '../data/cases';
import { patternA as data } from '../data/pattern-a';
import '../styles/global.css';

export function getStaticPaths() {
  return data.subpages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---
<Base title={`${page.titleJa} — IKILAB`} description={page.description}>
  <Header brand={data.brand} brandHref="/" navItems={data.navItems} contactHref={data.contactHref} />

  <div class="subpage-hero">
    <h1>{page.titleJa}</h1>
    <div class="hero-en">{page.title}</div>
    <p>{page.description}</p>
  </div>

  {page.slug === 'cases' ? (
    <div class="subpage-content subpage-content--wide">
      <div class="case-index-head">
        <h2>Case Archive</h2>
        <p>IKILABでは、取り組みを活動報告ではなく、仮説、実施、学びまで含めたケースとして蓄積しています。現在公開中の事例を紹介します。</p>
      </div>
      <div class="case-index-list">
        {cases.map((entry) => (
          <a href={`/cases/${entry.slug}`} class="case-index-card">
            <div class="case-index-meta">{entry.category}</div>
            <h3>{entry.title}</h3>
            <p>{entry.lead}</p>
            <span class="case-index-link">詳細を見る →</span>
          </a>
        ))}
      </div>
    </div>
  ) : (
    <div class="subpage-content">
      <h2>Coming Soon</h2>
      <p>このページは現在準備中です。トップページに戻って他のセクションをご覧ください。</p>
      <a href="/" class="btn-brutal btn-fill" style="display:inline-flex">トップに戻る →</a>
    </div>
  )}

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
