---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { cases } from '../data/cases';
import { homeData } from '../data/home';
import { siteData } from '../data/site';
import '../styles/global.css';

export function getStaticPaths() {
  return siteData.subpages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

// Projects listed only on /projects/ (not on top page)
const additionalProjects = [
  { status: "active", title: "壱岐なう", body: "船舶・航空の運航状況、気象、潮汐など、離島生活に不可欠なリアルタイム情報を一画面に集約するダッシュボード。壱岐カレンダーの姉妹プロジェクト。", href: "/projects/iki-now" },
  { status: "active", title: "壱岐市 人口シミュレーション", body: "社人研データをベースに壱岐市の将来人口動態をシミュレーション。施策効果の可視化と構造分析を通じて人口問題へのアプローチを探る。", href: "/projects/iki-pop-sim" },
];

const allProjects = [...homeData.experiments.items, ...additionalProjects];
const activeProjects = allProjects.filter((item) => item.status === 'active');
const plannedProjects = allProjects.filter((item) => item.status !== 'active');
---
<Base title={`${page.titleJa} — IKILAB`} description={page.description}>
  <Header brand={siteData.brand} brandHref="/" navItems={siteData.navItems} contactHref={siteData.contactHref} />

  <div class="subpage-hero">
    <h1>{page.titleJa}</h1>
    <div class="hero-en">{page.title}</div>
    <p>{page.description}</p>
  </div>

  {page.slug === 'cases' ? (
    <div class="subpage-content subpage-content--wide">
      <div class="case-index-head">
        <h2>Case Archive</h2>
        <p>IKILABでは、取り組みを活動報告ではなく、仮説、実施、学びまで含めたケースとして蓄積しています。現在公開中の事例を紹介します。</p>
      </div>
      <div class="case-index-list">
        {cases.map((entry) => (
          <a href={`/cases/${entry.slug}`} class="case-index-card">
            <div class="case-index-meta">{entry.category}</div>
            <h3>{entry.title}</h3>
            <p>{entry.lead}</p>
            <span class="case-index-link">詳細を見る →</span>
          </a>
        ))}
      </div>
    </div>
  ) : page.slug === 'projects' ? (
    <div class="subpage-content subpage-content--wide">
      <div class="case-index-head">
        <h2>Active Projects</h2>
        <p>IKILABが現在進めているプロジェクトです。詳細ページがあるものは、背景、構想、進捗、次の展開まで含めて見ることができます。</p>
      </div>
      <div class="case-index-list">
        {activeProjects.map((entry) => (
          entry.href ? (
            <a href={entry.href} class="case-index-card">
              <div class="case-index-meta">{entry.status}</div>
              <h3>{entry.title}</h3>
              <p>{entry.body}</p>
              <span class="case-index-link">詳細を見る →</span>
            </a>
          ) : (
            <div class="case-index-card case-index-card--disabled">
              <div class="case-index-meta">{entry.status}</div>
              <h3>{entry.title}</h3>
              <p>{entry.body}</p>
              <span class="case-index-link">詳細準備中</span>
            </div>
          )
        ))}
      </div>

      <div class="case-index-head project-index-head-secondary">
        <h2>Pipeline</h2>
        <p>構想・設計段階のテーマです。ヒアリングや試作を進めながら、壱岐島に合う形へと具体化していきます。</p>
      </div>
      <div class="case-index-list">
        {plannedProjects.map((entry) => (
          entry.href ? (
            <a href={entry.href} class="case-index-card">
              <div class="case-index-meta">{entry.status}</div>
              <h3>{entry.title}</h3>
              <p>{entry.body}</p>
              <span class="case-index-link">詳細を見る →</span>
            </a>
          ) : (
            <div class="case-index-card case-index-card--disabled">
              <div class="case-index-meta">{entry.status}</div>
              <h3>{entry.title}</h3>
              <p>{entry.body}</p>
              <span class="case-index-link">構想中</span>
            </div>
          )
        ))}
      </div>
    </div>
  ) : (
    <div class="subpage-content">
      <h2>Coming Soon</h2>
      <p>このページは現在準備中です。トップページに戻って他のセクションをご覧ください。</p>
      <a href="/" class="btn-brutal btn-fill" style="display:inline-flex">トップに戻る →</a>
    </div>
  )}

  <Footer brandFull={siteData.brandFull} brandDesc={siteData.brandDesc} copyright={siteData.copyright} columns={siteData.footerColumns} />
</Base>
