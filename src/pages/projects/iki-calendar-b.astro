---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';
import { siteData } from '../../data/site';
import '../../styles/global.css';

const entry = projects.find(p => p.slug === 'iki-calendar')!;
const Content = entry.Content;
---
<Base title={`${entry.title} — Design B — IKILAB`} description={entry.description}>
  <Header brand={siteData.brand} brandHref="/" navItems={siteData.navItems} contactHref={siteData.contactHref} />

  <!-- Hero: case-style split -->
  <section class="pdb-hero">
    <div class="pdb-hero-left">
      <div class="pdb-status">{entry.status}</div>
      <h1>{entry.title}</h1>
      <div class="pdb-en">{entry.en}</div>
      <p>{entry.lead}</p>
      <div class="pdb-actions">
        <a href="/projects" class="btn-brutal btn-ghost">一覧に戻る</a>
        {entry.externalHref && (
          <a href={entry.externalHref} target="_blank" rel="noreferrer" class="btn-brutal btn-fill">{entry.externalLabel} →</a>
        )}
      </div>
    </div>
    <aside class="pdb-hero-right">
      <div class="pdb-fact-label">Snapshot</div>
      {entry.snapshot.map((item) => (
        <div class="pdb-fact-row">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </aside>
  </section>

  <!-- Numbered sections -->
  <div class="pdb-section-bar"><span>01</span> WHY</div>
  <section class="pdb-body">
    <div class="pdb-markdown">
      <Content />
    </div>
  </section>

  <!-- Progress: horizontal timeline -->
  <div class="pdb-section-bar"><span>02</span> PROGRESS</div>
  <section class="pdb-progress">
    <div class="pdb-timeline-scroll">
      {entry.phases.map((phase, i) => (
        <div class={`pdb-phase-card ${phase.label === 'Phase 4' ? 'pdb-phase--current' : ''}`}>
          <div class="pdb-phase-num">{phase.label}</div>
          <h3>{phase.title}</h3>
          <p>{phase.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Focus -->
  <div class="pdb-section-bar pdb-section-bar--alt"><span>03</span> CURRENT FOCUS</div>
  <section class="pdb-focus">
    <div class="pdb-focus-grid">
      {entry.focus.map((item, index) => (
        <div class="pdb-focus-item">
          <span class="pdb-focus-num">{String(index + 1).padStart(2, '0')}</span>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Questions -->
  <div class="pdb-section-bar"><span>04</span> OPEN QUESTIONS</div>
  <section class="pdb-questions">
    {entry.questions.map((item) => (
      <div class="pdb-q-row">
        <span class="pdb-q-mark">?</span>
        <p>{item}</p>
      </div>
    ))}
  </section>

  <!-- CTA: dark full-width -->
  <section class="pdb-cta">
    <div class="pdb-cta-inner">
      <div class="pdb-cta-kicker">Connect</div>
      <h2>{entry.ctaTitle}</h2>
      <p>{entry.ctaBody}</p>
      <a href="/contact" class="btn-brutal btn-fill" style="background:var(--red);border-color:var(--red);">お問い合わせ →</a>
    </div>
  </section>

  <Footer brandFull={siteData.brandFull} brandDesc={siteData.brandDesc} copyright={siteData.copyright} columns={siteData.footerColumns} />
</Base>

<style is:global>
  .pdb-hero {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1fr 340px;
    min-height: 400px;
    border-bottom: var(--border);
  }
  .pdb-hero-left {
    padding: clamp(40px, 5vw, 72px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: var(--border);
  }
  .pdb-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }
  .pdb-hero h1 {
    font-family: var(--font-jp);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.25;
    margin-bottom: 6px;
  }
  .pdb-en {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--gray-500);
    margin-bottom: 20px;
  }
  .pdb-hero-left > p {
    color: var(--gray-700);
    max-width: 560px;
    margin-bottom: 24px;
  }
  .pdb-actions {
    display: flex;
    gap: 0;
  }
  .pdb-hero-right {
    padding: 32px 28px;
    background: var(--paper);
  }
  .pdb-fact-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 16px;
  }
  .pdb-fact-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-top: 1px solid rgba(0,0,0,0.06);
    font-size: 13px;
  }
  .pdb-fact-row span { color: var(--gray-500); }
  .pdb-fact-row strong { text-align: right; max-width: 60%; }

  .pdb-section-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px clamp(24px, 5vw, 72px);
    border-bottom: var(--border);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-500);
  }
  .pdb-section-bar span {
    font-weight: 700;
    color: var(--black);
    font-size: 14px;
  }
  .pdb-section-bar--alt {
    background: var(--paper);
  }

  .pdb-body {
    padding: clamp(40px, 5vw, 72px);
    border-bottom: var(--border);
    max-width: 800px;
  }
  .pdb-markdown h2 {
    font-family: var(--font-jp);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-top: 32px;
    margin-bottom: 6px;
  }
  .pdb-markdown h3 {
    font-family: var(--font-jp);
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 14px;
  }
  .pdb-markdown p {
    color: var(--gray-700);
    margin-bottom: 20px;
    line-height: 1.9;
  }

  .pdb-progress {
    padding: 40px clamp(24px, 5vw, 72px);
    border-bottom: var(--border);
    overflow-x: auto;
  }
  .pdb-timeline-scroll {
    display: flex;
    gap: 0;
    min-width: max-content;
  }
  .pdb-phase-card {
    min-width: 200px;
    flex: 1;
    padding: 24px 20px;
    border: 1px solid var(--gray-100);
    border-right: none;
    position: relative;
  }
  .pdb-phase-card:last-child { border-right: 1px solid var(--gray-100); }
  .pdb-phase--current {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }
  .pdb-phase-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-bottom: 8px;
  }
  .pdb-phase--current .pdb-phase-num { color: rgba(255,255,255,0.5); }
  .pdb-phase-card h3 {
    font-family: var(--font-jp);
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .pdb-phase-card p {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.6;
  }
  .pdb-phase--current p { color: rgba(255,255,255,0.6); }

  .pdb-focus {
    padding: 40px clamp(24px, 5vw, 72px);
    border-bottom: var(--border);
    background: var(--paper);
  }
  .pdb-focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0;
  }
  .pdb-focus-item {
    display: flex;
    gap: 12px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .pdb-focus-num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--gray-300);
    flex-shrink: 0;
  }
  .pdb-focus-item p { font-size: 14px; color: var(--gray-700); }

  .pdb-questions {
    padding: 40px clamp(24px, 5vw, 72px);
    border-bottom: var(--border);
  }
  .pdb-q-row {
    display: flex;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--gray-100);
    align-items: flex-start;
  }
  .pdb-q-mark {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    color: var(--red);
    flex-shrink: 0;
    line-height: 1.2;
  }
  .pdb-q-row p { font-size: 14px; color: var(--gray-700); }

  .pdb-cta {
    background: var(--black);
    color: var(--white);
    padding: clamp(48px, 6vw, 80px) clamp(24px, 5vw, 72px);
  }
  .pdb-cta-inner { max-width: 560px; }
  .pdb-cta-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 10px;
  }
  .pdb-cta h2 {
    font-family: var(--font-jp);
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .pdb-cta p {
    color: rgba(255,255,255,0.6);
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .pdb-hero { grid-template-columns: 1fr; }
    .pdb-hero-left { border-right: none; border-bottom: var(--border); }
  }
</style>
