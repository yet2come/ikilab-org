---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';
import { siteData } from '../../data/site';
import '../../styles/global.css';

const entry = projects.find(p => p.slug === 'iki-calendar')!;
const Content = entry.Content;
---
<Base title={`${entry.title} — Design A — IKILAB`} description={entry.description}>
  <Header brand={siteData.brand} brandHref="/" navItems={siteData.navItems} contactHref={siteData.contactHref} />

  <!-- Hero: minimal -->
  <section class="pda-hero">
    <span class="pda-badge">{entry.status}</span>
    <h1>{entry.title}</h1>
    <p>{entry.lead}</p>
  </section>

  <!-- 2-column dashboard -->
  <div class="pda-grid">
    <main class="pda-main">
      <div class="pda-markdown">
        <Content />
      </div>
      <section class="pda-focus">
        <h2>現在の取り組み</h2>
        <ul>
          {entry.focus.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </main>

    <aside class="pda-sidebar">
      <div class="pda-snap-list">
        {entry.snapshot.map((item) => (
          <div class="pda-snap-item">
            <div class="pda-snap-label">{item.label}</div>
            <div class="pda-snap-value">{item.value}</div>
          </div>
        ))}
      </div>

      <div class="pda-timeline">
        <h3>Progress</h3>
        {entry.phases.map((phase) => (
          <div class={`pda-phase ${phase.label === 'Phase 4' ? 'pda-phase--active' : ''}`}>
            <div class="pda-phase-dot"></div>
            <div>
              <div class="pda-phase-label">{phase.label} — {phase.title}</div>
              <p>{phase.body}</p>
            </div>
          </div>
        ))}
      </div>

      {entry.externalHref && (
        <a href={entry.externalHref} target="_blank" rel="noreferrer" class="pda-ext-link">{entry.externalLabel} →</a>
      )}
    </aside>
  </div>

  <!-- Questions: accordion style -->
  <section class="pda-questions">
    <h2>未解決の論点</h2>
    <div class="pda-q-list">
      {entry.questions.map((item, i) => (
        <details class="pda-q-item">
          <summary>{item}</summary>
          <p>この論点は現在検証中です。</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA bar -->
  <section class="pda-cta">
    <p>{entry.ctaTitle}</p>
    <a href="/contact" class="btn-brutal btn-fill">お問い合わせ →</a>
  </section>

  <Footer brandFull={siteData.brandFull} brandDesc={siteData.brandDesc} copyright={siteData.copyright} columns={siteData.footerColumns} />
</Base>

<style is:global>
  .pda-hero {
    margin-top: 56px;
    padding: 40px clamp(24px, 5vw, 72px) 32px;
    border-bottom: var(--border);
  }
  .pda-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
    padding: 3px 10px;
    margin-bottom: 12px;
  }
  .pda-hero h1 {
    font-family: var(--font-jp);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .pda-hero p {
    color: var(--gray-700);
    max-width: 640px;
  }

  .pda-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    border-bottom: var(--border);
  }

  .pda-main {
    padding: clamp(32px, 4vw, 56px) clamp(24px, 5vw, 72px);
    border-right: var(--border);
  }
  .pda-markdown h2 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-top: 32px;
    margin-bottom: 8px;
  }
  .pda-markdown h3 {
    font-family: var(--font-jp);
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .pda-markdown p {
    color: var(--gray-700);
    margin-bottom: 20px;
    line-height: 1.9;
  }

  .pda-focus {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--gray-100);
  }
  .pda-focus h2 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 16px;
  }
  .pda-focus ul {
    list-style: none;
  }
  .pda-focus li {
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
    font-size: 14px;
    color: var(--gray-700);
  }
  .pda-focus li::before {
    content: '→ ';
    color: var(--red);
    font-family: var(--font-mono);
  }

  .pda-sidebar {
    padding: clamp(32px, 4vw, 56px) 24px;
    background: var(--paper);
  }
  .pda-snap-item {
    padding: 14px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .pda-snap-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 4px;
  }
  .pda-snap-value {
    font-size: 13px;
    font-weight: 500;
  }

  .pda-timeline {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .pda-timeline h3 {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 16px;
  }
  .pda-phase {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    position: relative;
  }
  .pda-phase-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gray-300);
    margin-top: 4px;
    flex-shrink: 0;
  }
  .pda-phase--active .pda-phase-dot {
    background: var(--red);
  }
  .pda-phase-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .pda-phase p {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.5;
  }

  .pda-ext-link {
    display: block;
    margin-top: 24px;
    padding: 12px 16px;
    background: var(--black);
    color: var(--white);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-align: center;
    transition: background 0.2s;
  }
  .pda-ext-link:hover {
    background: var(--red);
  }

  .pda-questions {
    padding: 40px clamp(24px, 5vw, 72px);
    border-bottom: var(--border);
  }
  .pda-questions h2 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 16px;
  }
  .pda-q-item {
    border-bottom: 1px solid var(--gray-100);
  }
  .pda-q-item summary {
    padding: 14px 0;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    list-style: none;
  }
  .pda-q-item summary::before {
    content: '▸ ';
    color: var(--red);
    font-family: var(--font-mono);
  }
  .pda-q-item[open] summary::before {
    content: '▾ ';
  }
  .pda-q-item p {
    padding: 0 0 14px 16px;
    font-size: 13px;
    color: var(--gray-500);
  }

  .pda-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px clamp(24px, 5vw, 72px);
    border-bottom: var(--border);
    background: var(--paper);
  }
  .pda-cta p {
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .pda-grid {
      grid-template-columns: 1fr;
    }
    .pda-main {
      border-right: none;
      border-bottom: var(--border);
    }
    .pda-cta {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
