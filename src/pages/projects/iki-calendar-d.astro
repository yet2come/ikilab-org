---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { siteData } from '../../data/site';
import '../../styles/global.css';

const d = {
  title: '壱岐カレンダー',
  status: 'Operating',
  en: 'One calendar for a whole island.',
  lead: '島内に分散するイベント情報を一箇所に集約し、住民にも来島者にも「いつ・どこで・何があるか」が見渡せる状態をつくるプロジェクト。',
  externalLabel: 'ikical.com を見る',
  externalHref: 'https://ikical.com/',

  experiment: {
    what: 'SNS・チラシ・口コミに分散する壱岐島内のイベント情報を、1つのWebカレンダーに集約。日付・場所・カテゴリで検索・一覧できるPWAとして公開・運用中。',
    howDifferent: '行政の広報やポータルサイトは「公式情報」に限定されがち。壱岐カレンダーは公式・非公式を問わず、島民の自主活動やマルシェ、個人主催のワークショップまで拾い上げる「地域の全イベント一覧」を目指す点が異なる。',
  },

  phases: [
    { key: 'research', label: '課題整理' },
    { key: 'prototype', label: '試作' },
    { key: 'launch', label: '公開' },
    { key: 'operation', label: '運用改善' },
  ],
  currentPhaseKey: 'operation',
  currentFocus: [
    'SNSやチラシからの情報収集フローの効率化',
    '主催者が自ら投稿できる導線の整備',
    '更新負荷を下げる運用方法の検証',
    '利用者にとって探しやすいUIの改善',
  ],

  findings: {
    learnings: [
      '島内イベントを日付順に一覧できる状態が初めて実現し、「知らなかった」という声が減った。',
      'マップ機能により来島者がイベント会場を直感的に把握でき、回遊促進に寄与。',
      '多ジャンル（eスポーツ、サイクリング大会、セミナーなど）の情報が集まることで、従来届かなかった層にもリーチ。',
    ],
    challenges: [
      '情報収集が手動中心で、継続的な更新に負荷がかかっている。',
      '主催者による自主投稿はITリテラシーや習慣の壁があり、普及が遅い。',
      '日時変更・中止など情報の正確性担保が運用上の課題。',
    ],
    openQuestions: [
      '情報登録を主催者側の習慣にできるか',
      '地域の共通インフラとして、誰が運営主体になるのがよいか',
      '観光、地域活動、行政情報をどこまで統合するか',
    ],
  },

  next: {
    plans: [
      '主催者向け投稿フォームの簡素化とオンボーディング設計',
      '観光協会・自治体広報との連携による公式情報の自動取り込み',
      '飲食店・交通など他の地域情報との統合の検討',
    ],
    scalability: '技術的にはNext.js + PWAの汎用構成であり、他の離島や小規模自治体でも同様のカレンダーを構築可能。ただし、運用体制（誰が情報を集め続けるか）の設計が再現の鍵となる。',
  },

  involvement: [
    {
      who: 'company',
      label: '地域情報プラットフォームの共同開発',
      body: 'イベント集約の仕組みを他地域に展開したい、または技術面で連携したい企業の方へ。',
      examples: ['情報収集の自動化ツール提供', 'UI/UX改善の共同設計', 'データ連携APIの開発'],
    },
    {
      who: 'supporter',
      label: 'コンテンツ収集・運用サポート',
      body: '壱岐在住または壱岐に関わりのある方で、イベント情報の収集や掲載にご協力いただける方。',
      examples: ['月数回の情報収集・入力', 'SNS情報のピックアップ', '掲載内容の確認・校正'],
    },
    {
      who: 'researcher',
      label: '地域情報流通の研究・分析',
      body: '離島における情報格差や地域メディアの持続性に関心のある研究者の方へ。',
      examples: ['利用データの分析', '地域情報行動の調査設計', '他地域との比較研究'],
    },
    {
      who: 'individual',
      label: 'フィードバック・改善提案',
      body: '壱岐カレンダーを使っていて、改善点やアイデアがある方。ユーザーの声を反映します。',
      examples: ['使い勝手のフィードバック', '欲しい機能の提案', 'イベント情報の投稿'],
    },
  ],

  projectInfo: {
    milestones: [
      { date: '2023年後半', body: '島内イベント情報の分散状況を調査。集約基盤の必要性を確認。' },
      { date: '2024年前半', body: 'プロトタイプ開発。カレンダーUI・マップ連携・イベント詳細の基本構造を設計。' },
      { date: '2024年中盤', body: 'ikical.com として公開。情報収集と掲載を開始。' },
      { date: '2024年後半〜', body: '掲示板・フィードバック機能を追加。運用フローを改善しながら継続運用中。' },
    ],
    team: [
      { name: '（Members Only）', role: '企画・開発' },
      { name: '（Members Only）', role: '情報収集・運用' },
    ],
    relatedProjects: [
      { label: '壱岐なう', href: '#' },
      { label: '壱岐ロケ', href: '#' },
    ],
    links: [
      { label: '壱岐カレンダー（実サービス）', href: 'https://ikical.com/' },
    ],
  },
};

const sections = [
  { id: 'background', label: '背景' },
  { id: 'experiment', label: '実験内容' },
  { id: 'findings', label: '知見' },
  { id: 'involvement', label: '関わり方' },
  { id: 'info', label: 'プロジェクト情報' },
];

const whoLabels: Record<string, string> = {
  company: '企業',
  individual: '個人',
  researcher: '研究者',
  supporter: 'サポーター',
};
---
<Base title={`${d.title} — IKILAB`} description={d.lead}>
  <Header brand={siteData.brand} brandHref="/" navItems={siteData.navItems} contactHref={siteData.contactHref} />

  <!-- 1. Hero -->
  <section class="pdd-hero">
    <div class="pdd-hero-inner">
      <span class="pdd-badge">{d.status}</span>
      <h1>{d.title}</h1>
      <div class="pdd-en">{d.en}</div>
      <p>{d.lead}</p>
      <div class="pdd-hero-actions">
        <a href="/projects" class="btn-brutal btn-ghost">一覧に戻る</a>
        {d.externalHref && <a href={d.externalHref} target="_blank" rel="noreferrer" class="btn-brutal btn-fill">{d.externalLabel}</a>}
      </div>
    </div>
  </section>

  <!-- 2. Section nav -->
  <nav class="pdd-nav">
    {sections.map(s => <a href={`#${s.id}`} class="pdd-nav-link">{s.label}</a>)}
  </nav>

  <!-- 3. 課題と背景 -->
  <div class="pdd-bar"><span>01</span> BACKGROUND</div>
  <section id="background" class="pdd-section">
    <div class="pdd-col">
      <h3>どんな問題か</h3>
      <p>壱岐島では祭り、マルシェ、ワークショップ、行政の催しなど多くのイベントが開催されています。しかし、それらの情報はFacebook、Instagram、LINE、紙のチラシ、口コミに分散し、「いつ・どこで・何があるのか」を網羅的に把握する手段がありません。</p>
    </div>
    <div class="pdd-col">
      <h3>なぜ壱岐でやるのか</h3>
      <p>人口約23,000人の島という閉じたフィールドだからこそ、「島内の全イベント」という範囲設定が現実的に成り立ちます。都市では不可能な「全量把握」を、離島の規模を活かして実現できます。</p>
    </div>
    <div class="pdd-col">
      <h3>なぜ今やるのか</h3>
      <p>人口減少に伴い地域活動の担い手が減る中で、イベントの告知・集客コストが年々上がっています。情報が届かないことで参加者が減り、活動が縮小する悪循環が始まる前に、情報基盤を整えておく必要があります。</p>
    </div>
  </section>

  <!-- 4. 実験内容 -->
  <div class="pdd-bar"><span>02</span> EXPERIMENT</div>
  <section id="experiment" class="pdd-section">
    <div class="pdd-col">
      <h3>何をどう試しているか</h3>
      <p>{d.experiment.what}</p>
    </div>
    <div class="pdd-col">
      <h3>従来と何が違うか</h3>
      <p>{d.experiment.howDifferent}</p>
    </div>
  </section>

  <!-- 5. 現在のステータス -->
  <div class="pdd-bar pdd-bar--alt"><span>03</span> STATUS</div>
  <section class="pdd-section pdd-section--alt">
    <div class="pdd-stepper">
      {d.phases.map((phase, i) => (
        <div class={`pdd-step ${phase.key === d.currentPhaseKey ? 'pdd-step--active' : ''}`}>
          <div class="pdd-step-indicator">
            <div class="pdd-step-dot"></div>
            {i < d.phases.length - 1 && <div class="pdd-step-line"></div>}
          </div>
          <div class="pdd-step-label">{phase.label}</div>
        </div>
      ))}
    </div>
    <h3>現在の取り組み</h3>
    <ul class="pdd-focus-list">
      {d.currentFocus.map(item => <li>{item}</li>)}
    </ul>
  </section>

  <!-- 6. 知見・途中結果 -->
  <div class="pdd-bar"><span>04</span> FINDINGS</div>
  <section id="findings" class="pdd-section">
    <div class="pdd-findings-group">
      <h3>見えてきたこと</h3>
      {d.findings.learnings.map(item => (
        <div class="pdd-finding-row pdd-finding--learning"><span>○</span><p>{item}</p></div>
      ))}
    </div>
    <div class="pdd-findings-group">
      <h3>課題として残っていること</h3>
      {d.findings.challenges.map(item => (
        <div class="pdd-finding-row pdd-finding--challenge"><span>△</span><p>{item}</p></div>
      ))}
    </div>
    <div class="pdd-findings-group">
      <h3>まだ答えの出ていない問い</h3>
      {d.findings.openQuestions.map(item => (
        <div class="pdd-finding-row pdd-finding--question"><span>?</span><p>{item}</p></div>
      ))}
    </div>
  </section>

  <!-- 7. 今後の展開 -->
  <div class="pdd-bar pdd-bar--alt"><span>05</span> NEXT</div>
  <section class="pdd-section pdd-section--alt">
    <h3>次にやること</h3>
    <ul class="pdd-focus-list">
      {d.next.plans.map(item => <li>{item}</li>)}
    </ul>
    <h3>再現性の見立て</h3>
    <p class="pdd-scalability">{d.next.scalability}</p>
  </section>

  <!-- 8. 関われる余地 + CTA -->
  <div class="pdd-bar"><span>06</span> INVOLVEMENT</div>
  <section id="involvement" class="pdd-section">
    <div class="pdd-involve-grid">
      {d.involvement.map(inv => (
        <div class="pdd-involve-card">
          <div class="pdd-involve-who">{whoLabels[inv.who] || inv.who}</div>
          <h3>{inv.label}</h3>
          <p>{inv.body}</p>
          {inv.examples && inv.examples.length > 0 && (
            <ul class="pdd-involve-examples">
              {inv.examples.map(ex => <li>{ex}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
    <div class="pdd-mid-cta">
      <p>壱岐カレンダーに関わりたい方はお気軽にご連絡ください。</p>
      <a href="/contact" class="btn-brutal btn-fill">お問い合わせ →</a>
    </div>
  </section>

  <!-- 9. プロジェクト情報 -->
  <div class="pdd-bar pdd-bar--alt"><span>07</span> PROJECT INFO</div>
  <section id="info" class="pdd-section pdd-section--alt">
    <!-- 経緯 -->
    <h3>タイムライン</h3>
    <div class="pdd-milestones">
      {d.projectInfo.milestones.map(ms => (
        <div class="pdd-milestone">
          <span class="pdd-milestone-date">{ms.date}</span>
          <p>{ms.body}</p>
        </div>
      ))}
    </div>

    <div class="pdd-info-grid">
      <div>
        <h4>体制</h4>
        {d.projectInfo.team.map(member => (
          <div class="pdd-team-row">
            <span class="pdd-team-role">{member.role}</span>
            <span>{member.name}</span>
          </div>
        ))}
      </div>
      <div>
        <h4>関連プロジェクト</h4>
        {d.projectInfo.relatedProjects.map(rp => (
          <a href={rp.href} class="pdd-info-link">{rp.label} →</a>
        ))}
      </div>
      <div>
        <h4>関連リンク</h4>
        {d.projectInfo.links.map(link => (
          <a href={link.href} target="_blank" rel="noreferrer" class="pdd-info-link">{link.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <!-- 10. CTA（2回目） -->
  <section class="pdd-final-cta">
    <div class="pdd-final-cta-inner">
      <div class="pdd-cta-kicker">Connect</div>
      <h2>このプロジェクトに関心がある方へ</h2>
      <p>地域イベントの集約、情報導線の設計、持続可能な運用モデルなど、地域の情報課題に一緒に取り組みたい方はご連絡ください。</p>
      <a href="/contact" class="btn-brutal btn-fill" style="background:var(--red);border-color:var(--red);">お問い合わせ →</a>
    </div>
  </section>

  <Footer brandFull={siteData.brandFull} brandDesc={siteData.brandDesc} copyright={siteData.copyright} columns={siteData.footerColumns} />
</Base>

<style is:global>
/* ============ PROTOTYPE D ============ */
.pdd-hero {
  margin-top: 56px;
  padding: clamp(40px, 6vw, 72px) clamp(24px, 5vw, 72px);
  border-bottom: var(--border);
}
.pdd-hero-inner { max-width: 680px; }
.pdd-badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--white);
  background: var(--red);
  padding: 3px 10px;
  margin-bottom: 14px;
}
.pdd-hero h1 {
  font-family: var(--font-jp);
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 6px;
}
.pdd-en {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 18px;
  color: var(--gray-500);
  margin-bottom: 18px;
}
.pdd-hero p { color: var(--gray-700); max-width: 600px; margin-bottom: 24px; }
.pdd-hero-actions { display: flex; gap: 0; }

/* Section nav */
.pdd-nav {
  display: flex;
  overflow-x: auto;
  border-bottom: var(--border);
  background: var(--white);
  position: sticky;
  top: 56px;
  z-index: 50;
}
.pdd-nav-link {
  display: inline-block;
  padding: 14px 20px;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--gray-500);
  white-space: nowrap;
  border-right: 1px solid var(--gray-100);
  transition: all 0.15s;
}
.pdd-nav-link:hover { background: var(--black); color: var(--white); }

/* Section bar */
.pdd-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px clamp(24px, 5vw, 72px);
  border-bottom: var(--border);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gray-500);
}
.pdd-bar span { font-weight: 700; color: var(--black); font-size: 14px; }
.pdd-bar--alt { background: var(--paper); }

/* Section */
.pdd-section {
  padding: clamp(32px, 5vw, 56px) clamp(24px, 5vw, 72px);
  border-bottom: var(--border);
  scroll-margin-top: 100px;
}
.pdd-section--alt { background: var(--paper); }
.pdd-section h3 {
  font-family: var(--font-jp);
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 10px;
  margin-top: 28px;
}
.pdd-section h3:first-child { margin-top: 0; }
.pdd-section p { color: var(--gray-700); line-height: 1.9; margin-bottom: 16px; max-width: 720px; }

/* Columns */
.pdd-col { margin-bottom: 8px; }

/* Stepper */
.pdd-stepper {
  display: flex;
  gap: 0;
  margin-bottom: 32px;
}
.pdd-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.pdd-step-indicator {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 10px;
}
.pdd-step-dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--gray-300);
  flex-shrink: 0;
  z-index: 1;
}
.pdd-step--active .pdd-step-dot {
  background: var(--red);
  box-shadow: 0 0 0 4px var(--red-dim);
}
.pdd-step-line {
  flex: 1;
  height: 2px;
  background: var(--gray-100);
}
.pdd-step-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.06em;
  color: var(--gray-500);
}
.pdd-step--active .pdd-step-label { color: var(--black); font-weight: 600; }

/* Focus list */
.pdd-focus-list {
  list-style: none;
  max-width: 720px;
}
.pdd-focus-list li {
  padding: 10px 0;
  border-bottom: 1px solid rgba(0,0,0,0.06);
  font-size: 14px;
  color: var(--gray-700);
}
.pdd-focus-list li::before { content: '→ '; color: var(--red); font-family: var(--font-mono); }

/* Findings */
.pdd-findings-group { margin-bottom: 28px; }
.pdd-finding-row {
  display: flex;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid var(--gray-100);
  align-items: flex-start;
}
.pdd-finding-row span {
  font-family: var(--font-mono);
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
  width: 24px;
  text-align: center;
  line-height: 1.4;
}
.pdd-finding--learning span { color: #16a34a; }
.pdd-finding--challenge span { color: #d97706; }
.pdd-finding--question span { color: var(--red); font-family: var(--font-serif); font-size: 20px; }
.pdd-finding-row p { font-size: 14px; color: var(--gray-700); margin-bottom: 0; }

/* Scalability */
.pdd-scalability {
  padding: 20px 24px;
  background: var(--white);
  border: 1px solid var(--gray-100);
  border-left: 3px solid var(--red);
  font-size: 14px;
}

/* Involvement */
.pdd-involve-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
  margin-bottom: 32px;
}
.pdd-involve-card {
  padding: 24px;
  border: var(--border);
  background: var(--white);
}
.pdd-involve-who {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 8px;
}
.pdd-involve-card h3 {
  font-size: 16px;
  margin-top: 0;
  margin-bottom: 8px;
}
.pdd-involve-card p { font-size: 13px; margin-bottom: 10px; }
.pdd-involve-examples {
  list-style: none;
}
.pdd-involve-examples li {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--gray-500);
  padding: 3px 0;
}
.pdd-involve-examples li::before { content: '· '; }

.pdd-mid-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 28px;
  background: var(--paper);
  border: var(--border);
}
.pdd-mid-cta p { font-weight: 500; margin-bottom: 0; }

/* Project Info */
/* Milestones */
.pdd-milestones {
  margin-bottom: 36px;
  max-width: 720px;
}
.pdd-milestone {
  display: flex;
  gap: 16px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(0,0,0,0.06);
  align-items: baseline;
}
.pdd-milestone-date {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--gray-500);
  white-space: nowrap;
  min-width: 100px;
  flex-shrink: 0;
}
.pdd-milestone p {
  font-size: 13px;
  color: var(--gray-700);
  margin-bottom: 0;
}

.pdd-info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.pdd-info-grid h4 {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
