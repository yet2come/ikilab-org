---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';

const variants = [
  {
    slug: 'panel',
    title: 'Proposal 01',
    name: 'Panel Drop',
    body: 'ヘッダー直下にそのまま落ちる、最小変更の案。既存の無骨なUIに一番なじみます。',
  },
  {
    slug: 'grid',
    title: 'Proposal 02',
    name: 'Grid Card',
    body: 'カード状に整理する案。項目数が増えても視認性が落ちにくく、比較しやすい構成です。',
  },
  {
    slug: 'editorial',
    title: 'Proposal 03',
    name: 'Editorial Overlay',
    body: '全面を使う案。ブランド感は最も強いですが、演出の主張も強めです。',
  },
  {
    slug: 'slide',
    title: 'Proposal 04',
    name: 'Slide Drawer',
    body: '右端からスライドインするドロワー型。ホバーで左ボーダーにアクセントカラーが入ります。',
  },
  {
    slug: 'minimal',
    title: 'Proposal 05',
    name: 'Minimal Card',
    body: '画面中央に小さなカードで表示。装飾を削ぎ落とし、余白で呼吸感を出す案。',
  },
  {
    slug: 'bottom-sheet',
    title: 'Proposal 06',
    name: 'Bottom Sheet',
    body: '画面下部からスライドアップ。親指操作を意識したモバイルアプリ的アプローチ。',
  },
];
---
<Base title="Mobile Menu Proposals — IKILAB" description="IKILAB mobile menu design proposals.">
  <main class="menu-proposals-page">
    <div class="menu-proposals-head">
      <div class="menu-proposals-kicker">Preview</div>
      <h1>Mobile Menu Proposals</h1>
      <p>各ページをモバイル幅で開くと、ハンバーガーメニューの3案を確認できます。</p>
    </div>

    <div class="menu-proposals-grid">
      {variants.map((variant) => (
        <a href={`/menu-proposals/${variant.slug}/`} class="menu-proposal-card">
          <div class="menu-proposal-num">{variant.title}</div>
          <h2>{variant.name}</h2>
          <p>{variant.body}</p>
          <span>Open preview →</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style is:global>
  .menu-proposals-page {
    min-height: 100vh;
    padding: 104px 24px 40px;
    background: linear-gradient(180deg, #f7f4ee 0%, #fafafa 100%);
  }

  .menu-proposals-head {
    max-width: 720px;
    margin: 0 auto 32px;
  }

  .menu-proposals-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 10px;
  }

  .menu-proposals-head h1 {
    font-family: var(--font-jp);
    font-size: clamp(34px, 6vw, 56px);
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .menu-proposals-head p {
    color: var(--gray-700);
    max-width: 640px;
  }

  .menu-proposals-grid {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .menu-proposal-card {
    display: block;
    padding: 22px;
    background: var(--white);
    border: var(--border);
    color: inherit;
    text-decoration: none;
    min-height: 220px;
  }

  .menu-proposal-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 12px;
  }

  .menu-proposal-card h2 {
    font-family: var(--font-jp);
    font-size: 26px;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .menu-proposal-card p {
    color: var(--gray-700);
    margin-bottom: 20px;
  }

  .menu-proposal-card span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .menu-proposals-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
