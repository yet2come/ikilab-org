---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';

const variants = [
  {
    slug: 'slide-a6',
    title: 'A6 Base',
    name: '300ms 等間隔',
    body: '各リンク300ms間隔。1つずつ順に出てくるのが見える。',
  },
  {
    slug: 'slide-a6b',
    title: 'A6b',
    name: '600ms 等間隔',
    body: '各リンク600ms間隔。はっきり時差が見え、演出感が出る。',
  },
  {
    slug: 'slide-a6c',
    title: 'A6c',
    name: '1000ms 等間隔',
    body: '各リンク1秒間隔。非常にゆっくり、1つずつ登場する。',
  },
  {
    slug: 'slide-a6d',
    title: 'A6d',
    name: '加速型',
    body: '最初はゆっくり、後ろに向かって速くなる。加速感のある登場。',
  },
  {
    slug: 'slide-a6e',
    title: 'A6e',
    name: '減速型',
    body: '最初は一気に出て、後ろがゆっくり。余韻を残す登場。',
  },
  {
    slug: 'slide-a6f',
    title: 'A6f',
    name: '一斉＋末尾遅延',
    body: '上5つは200msで一斉、最後の2つ（Population・Contact）が1.5s・3sで遅れて出る。',
  },
];
---
<Base title="Mobile Menu Proposals — IKILAB" description="IKILAB mobile menu design proposals.">
  <main class="menu-proposals-page">
    <div class="menu-proposals-head">
      <div class="menu-proposals-kicker">Preview</div>
      <h1>Mobile Menu Proposals</h1>
      <p>各ページをモバイル幅で開くと、ハンバーガーメニューの3案を確認できます。</p>
    </div>

    <div class="menu-proposals-grid">
      {variants.map((variant) => (
        <a href={`/menu-proposals/${variant.slug}/`} class="menu-proposal-card">
          <div class="menu-proposal-num">{variant.title}</div>
          <h2>{variant.name}</h2>
          <p>{variant.body}</p>
          <span>Open preview →</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style is:global>
  .menu-proposals-page {
    min-height: 100vh;
    padding: 104px 24px 40px;
    background: linear-gradient(180deg, #f7f4ee 0%, #fafafa 100%);
  }

  .menu-proposals-head {
    max-width: 720px;
    margin: 0 auto 32px;
  }

  .menu-proposals-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 10px;
  }

  .menu-proposals-head h1 {
    font-family: var(--font-jp);
    font-size: clamp(34px, 6vw, 56px);
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .menu-proposals-head p {
    color: var(--gray-700);
    max-width: 640px;
  }

  .menu-proposals-grid {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .menu-proposal-card {
    display: block;
    padding: 22px;
    background: var(--white);
    border: var(--border);
    color: inherit;
    text-decoration: none;
    min-height: 220px;
  }

  .menu-proposal-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 12px;
  }

  .menu-proposal-card h2 {
    font-family: var(--font-jp);
    font-size: 26px;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .menu-proposal-card p {
    color: var(--gray-700);
    margin-bottom: 20px;
  }

  .menu-proposal-card span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .menu-proposals-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
