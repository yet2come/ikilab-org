---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';

const variants = [
  {
    slug: 'slide-a',
    title: 'Base',
    name: 'Slide Compact',
    body: 'ベース案。JetBrains Mono + Zen Kaku Gothic New。モノスペース強調。',
  },
  {
    slug: 'slide-a1',
    title: 'Font 01',
    name: 'Serif + Gothic',
    body: 'Instrument Serif（英語）+ Zen Kaku Gothic New（日本語）。クラシックで知的。',
  },
  {
    slug: 'slide-a2',
    title: 'Font 02',
    name: 'Noto Sans 統一',
    body: 'Noto Sans JP で英日統一。すっきり読みやすいモダンな印象。',
  },
  {
    slug: 'slide-a3',
    title: 'Font 03',
    name: 'Gothic 太字',
    body: 'Zen Kaku Gothic New で英日統一。太めウェイトで力強い印象。',
  },
  {
    slug: 'slide-a4',
    title: 'Font 04',
    name: 'Serif Italic',
    body: 'Instrument Serif イタリック（英語）+ Noto Sans JP（日本語）。エディトリアル風。',
  },
  {
    slug: 'slide-a5',
    title: 'Font 05',
    name: 'Mono 全振り',
    body: 'JetBrains Mono で英日ともに表示。ターミナル的・テック感全開。',
  },
  {
    slug: 'slide-a6',
    title: 'Font 06',
    name: 'Serif 大 + Gothic 小',
    body: 'Instrument Serif 大きめ + Zen Kaku Gothic New 小さめ。サイズコントラスト強め。',
  },
];
---
<Base title="Mobile Menu Proposals — IKILAB" description="IKILAB mobile menu design proposals.">
  <main class="menu-proposals-page">
    <div class="menu-proposals-head">
      <div class="menu-proposals-kicker">Preview</div>
      <h1>Mobile Menu Proposals</h1>
      <p>各ページをモバイル幅で開くと、ハンバーガーメニューの3案を確認できます。</p>
    </div>

    <div class="menu-proposals-grid">
      {variants.map((variant) => (
        <a href={`/menu-proposals/${variant.slug}/`} class="menu-proposal-card">
          <div class="menu-proposal-num">{variant.title}</div>
          <h2>{variant.name}</h2>
          <p>{variant.body}</p>
          <span>Open preview →</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style is:global>
  .menu-proposals-page {
    min-height: 100vh;
    padding: 104px 24px 40px;
    background: linear-gradient(180deg, #f7f4ee 0%, #fafafa 100%);
  }

  .menu-proposals-head {
    max-width: 720px;
    margin: 0 auto 32px;
  }

  .menu-proposals-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 10px;
  }

  .menu-proposals-head h1 {
    font-family: var(--font-jp);
    font-size: clamp(34px, 6vw, 56px);
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .menu-proposals-head p {
    color: var(--gray-700);
    max-width: 640px;
  }

  .menu-proposals-grid {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .menu-proposal-card {
    display: block;
    padding: 22px;
    background: var(--white);
    border: var(--border);
    color: inherit;
    text-decoration: none;
    min-height: 220px;
  }

  .menu-proposal-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 12px;
  }

  .menu-proposal-card h2 {
    font-family: var(--font-jp);
    font-size: 26px;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .menu-proposal-card p {
    color: var(--gray-700);
    margin-bottom: 20px;
  }

  .menu-proposal-card span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .menu-proposals-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
