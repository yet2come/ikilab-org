---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { siteData } from '../../data/site';
import '../../styles/global.css';

const variants = {
  'slide-a': {
    title: 'Slide Compact (Base)',
    body: 'ベース案。JetBrains Mono + Zen Kaku Gothic New。モノスペース強調のコンパクト設計。',
  },
  'slide-a1': {
    title: 'Tap Flash',
    body: 'タップ時に背景が赤く光って戻ります。最もシンプルなタッチフィードバック。',
  },
  'slide-a2': {
    title: 'Tap Invert',
    body: 'タップ時に黒背景・白テキストに反転します。押した実感が強い演出。',
  },
  'slide-a3': {
    title: 'Stagger Slide',
    body: 'メニュー開時にリンクが右から時差でスライドイン。タップで赤く光ります。',
  },
  'slide-a4': {
    title: 'Stagger Fade Up',
    body: 'メニュー開時にリンクが下からフェードアップ。タップで番号が赤くなります。',
  },
  'slide-a5': {
    title: 'Tap Scale',
    body: 'タップ時に少し縮んで押下感を演出。番号が赤くなります。',
  },
  'slide-a6': {
    title: 'Bar + Stagger',
    body: '開時スライドイン＋タップで左ボーダー赤＋背景フラッシュの合わせ技です。',
  },
} as const;

export function getStaticPaths() {
  return ['slide-a', 'slide-a1', 'slide-a2', 'slide-a3', 'slide-a4', 'slide-a5', 'slide-a6'].map((variant) => ({
    params: { variant },
    props: { variant },
  }));
}

const { variant } = Astro.props as { variant: keyof typeof variants };
const current = variants[variant];
---
<Base title={`${current.title} — IKILAB`} description={current.body}>
  <Header
    brand={siteData.brand}
    brandHref="/"
    navItems={siteData.navItems}
    contactHref={siteData.contactHref}
    mobileMenuVariant={variant}
  />

  <main class="menu-proposal-preview">
    <section class="menu-proposal-hero">
      <div class="menu-proposal-eyebrow">Mobile Menu Preview</div>
      <h1>{current.title}</h1>
      <p>{current.body}</p>
      <div class="menu-proposal-links">
        <a href="/menu-proposals/" class="btn-brutal btn-ghost">一覧に戻る</a>
        <a href="/" class="btn-brutal btn-fill">本サイトへ →</a>
      </div>
    </section>
    <section class="menu-proposal-note">
      <p>このページはモバイル幅で開くと、ヘッダー右上のハンバーガーボタンからメニューを確認できます。</p>
    </section>
  </main>
</Base>

<style is:global>
  .menu-proposal-preview {
    min-height: 100vh;
    padding: 112px 20px 32px;
    background:
      radial-gradient(circle at top right, rgba(212, 43, 30, 0.10), transparent 30%),
      linear-gradient(180deg, #f8f6f1 0%, #fafafa 100%);
  }

  .menu-proposal-hero {
    max-width: 720px;
    margin: 0 auto 24px;
    padding: 28px;
    background: rgba(255,255,255,0.84);
    backdrop-filter: blur(12px);
    border: var(--border);
  }

  .menu-proposal-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 10px;
  }

  .menu-proposal-hero h1 {
    font-family: var(--font-jp);
    font-size: clamp(36px, 8vw, 56px);
    line-height: 1.15;
    margin-bottom: 12px;
  }

  .menu-proposal-hero p {
    max-width: 560px;
    color: var(--gray-700);
    margin-bottom: 22px;
  }

  .menu-proposal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .menu-proposal-note {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 28px;
    background: var(--white);
    border: var(--border);
    color: var(--gray-700);
  }
</style>
