---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { siteData } from '../../data/site';
import '../../styles/global.css';

const variants = {
  'slide-a6': {
    title: '300ms 等間隔',
    body: '各リンク300ms間隔。1つずつ順に出てくるのが見えます。',
  },
  'slide-a6b': {
    title: '600ms 等間隔',
    body: '各リンク600ms間隔。はっきり時差が見え、演出感が出ます。',
  },
  'slide-a6c': {
    title: '1000ms 等間隔',
    body: '各リンク1秒間隔。非常にゆっくり、1つずつ登場します。',
  },
  'slide-a6d': {
    title: '加速型',
    body: '最初はゆっくり、後ろに向かって速くなります。加速感のある登場。',
  },
  'slide-a6e': {
    title: '減速型',
    body: '最初は一気に出て、後ろがゆっくり。余韻を残す登場です。',
  },
  'slide-a6f': {
    title: '一斉＋末尾遅延',
    body: '上5つは200msで一斉、最後の2つが1.5s・3sで遅れて出ます。',
  },
} as const;

export function getStaticPaths() {
  return ['slide-a6', 'slide-a6b', 'slide-a6c', 'slide-a6d', 'slide-a6e', 'slide-a6f'].map((variant) => ({
    params: { variant },
    props: { variant },
  }));
}

const { variant } = Astro.props as { variant: keyof typeof variants };
const current = variants[variant];
---
<Base title={`${current.title} — IKILAB`} description={current.body}>
  <Header
    brand={siteData.brand}
    brandHref="/"
    navItems={siteData.navItems}
    contactHref={siteData.contactHref}
    mobileMenuVariant={variant}
  />

  <main class="menu-proposal-preview">
    <section class="menu-proposal-hero">
      <div class="menu-proposal-eyebrow">Mobile Menu Preview</div>
      <h1>{current.title}</h1>
      <p>{current.body}</p>
      <div class="menu-proposal-links">
        <a href="/menu-proposals/" class="btn-brutal btn-ghost">一覧に戻る</a>
        <a href="/" class="btn-brutal btn-fill">本サイトへ →</a>
      </div>
    </section>
    <section class="menu-proposal-note">
      <p>このページはモバイル幅で開くと、ヘッダー右上のハンバーガーボタンからメニューを確認できます。</p>
    </section>
  </main>
</Base>

<style is:global>
  .menu-proposal-preview {
    min-height: 100vh;
    padding: 112px 20px 32px;
    background:
      radial-gradient(circle at top right, rgba(212, 43, 30, 0.10), transparent 30%),
      linear-gradient(180deg, #f8f6f1 0%, #fafafa 100%);
  }

  .menu-proposal-hero {
    max-width: 720px;
    margin: 0 auto 24px;
    padding: 28px;
    background: rgba(255,255,255,0.84);
    backdrop-filter: blur(12px);
    border: var(--border);
  }

  .menu-proposal-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 10px;
  }

  .menu-proposal-hero h1 {
    font-family: var(--font-jp);
    font-size: clamp(36px, 8vw, 56px);
    line-height: 1.15;
    margin-bottom: 12px;
  }

  .menu-proposal-hero p {
    max-width: 560px;
    color: var(--gray-700);
    margin-bottom: 22px;
  }

  .menu-proposal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .menu-proposal-note {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 28px;
    background: var(--white);
    border: var(--border);
    color: var(--gray-700);
  }
</style>
