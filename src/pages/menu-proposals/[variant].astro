---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { siteData } from '../../data/site';
import '../../styles/global.css';

const variants = {
  panel: {
    title: 'Panel Drop',
    body: '最小変更で既存のヘッダー文法に寄せた案です。横並びナビをそのまま縦積みに変換します。',
  },
  grid: {
    title: 'Grid Card',
    body: '情報をカードとして並べる案です。回遊性を保ちつつ、メニュー自体に少し楽しさを持たせています。',
  },
  editorial: {
    title: 'Editorial Overlay',
    body: 'ブランド表現を優先する全面オーバーレイ案です。没入感は強いですが、UIの主張も強めです。',
  },
  slide: {
    title: 'Slide Drawer',
    body: '右端からスライドインするドロワー型です。ホバーで左ボーダーにアクセントカラーが入ります。',
  },
  'slide-a': {
    title: 'Slide Compact',
    body: 'Slideベースのナロー版。幅240px、モノスペース強調、インデックス番号を大きく表示します。',
  },
  'slide-b': {
    title: 'Slide Dark',
    body: 'Slideベースのダーク版。セリフ体の英語ラベルと赤アクセントでブランド感を重視します。',
  },
  'slide-c': {
    title: 'Slide Wide',
    body: 'Slideベースのワイド版。カード風リンクと紙のような背景で柔らかい印象を与えます。',
  },
  minimal: {
    title: 'Minimal Card',
    body: '画面中央に小さなカードで表示する案です。装飾を削ぎ落とし、余白で呼吸感を出します。',
  },
  'bottom-sheet': {
    title: 'Bottom Sheet',
    body: '画面下部からスライドアップする案です。親指操作を意識したモバイルアプリ的アプローチ。',
  },
} as const;

export function getStaticPaths() {
  return ['panel', 'grid', 'editorial', 'slide', 'slide-a', 'slide-b', 'slide-c', 'minimal', 'bottom-sheet'].map((variant) => ({
    params: { variant },
    props: { variant },
  }));
}

const { variant } = Astro.props as { variant: keyof typeof variants };
const current = variants[variant];
---
<Base title={`${current.title} — IKILAB`} description={current.body}>
  <Header
    brand={siteData.brand}
    brandHref="/"
    navItems={siteData.navItems}
    contactHref={siteData.contactHref}
    mobileMenuVariant={variant}
  />

  <main class="menu-proposal-preview">
    <section class="menu-proposal-hero">
      <div class="menu-proposal-eyebrow">Mobile Menu Preview</div>
      <h1>{current.title}</h1>
      <p>{current.body}</p>
      <div class="menu-proposal-links">
        <a href="/menu-proposals/" class="btn-brutal btn-ghost">一覧に戻る</a>
        <a href="/" class="btn-brutal btn-fill">本サイトへ →</a>
      </div>
    </section>
    <section class="menu-proposal-note">
      <p>このページはモバイル幅で開くと、ヘッダー右上のハンバーガーボタンからメニューを確認できます。</p>
    </section>
  </main>
</Base>

<style is:global>
  .menu-proposal-preview {
    min-height: 100vh;
    padding: 112px 20px 32px;
    background:
      radial-gradient(circle at top right, rgba(212, 43, 30, 0.10), transparent 30%),
      linear-gradient(180deg, #f8f6f1 0%, #fafafa 100%);
  }

  .menu-proposal-hero {
    max-width: 720px;
    margin: 0 auto 24px;
    padding: 28px;
    background: rgba(255,255,255,0.84);
    backdrop-filter: blur(12px);
    border: var(--border);
  }

  .menu-proposal-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 10px;
  }

  .menu-proposal-hero h1 {
    font-family: var(--font-jp);
    font-size: clamp(36px, 8vw, 56px);
    line-height: 1.15;
    margin-bottom: 12px;
  }

  .menu-proposal-hero p {
    max-width: 560px;
    color: var(--gray-700);
    margin-bottom: 22px;
  }

  .menu-proposal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .menu-proposal-note {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 28px;
    background: var(--white);
    border: var(--border);
    color: var(--gray-700);
  }
</style>
