---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionBar from '../components/SectionBar.astro';
import HeroSection from '../components/HeroSection.astro';
import WhySection from '../components/WhySection.astro';
import ExperimentsGrid from '../components/ExperimentsGrid.astro';
import ProofSection from '../components/ProofSection.astro';
import ConnectSection from '../components/ConnectSection.astro';
import InfraSection from '../components/InfraSection.astro';
import { homeData } from '../data/home';
import { siteData } from '../data/site';
import '../styles/global.css';
---
<Base title="IKILAB — 島内外を接続する実験装置" description="IKILABは、島内外を接続する実験装置です。人口25,000人の壱岐島を舞台に、地域の課題を構造的に解き、新しい接続を生み出します。">
  <Header brand={siteData.brand} brandHref="/" navItems={siteData.navItems} contactHref={siteData.contactHref} />

  <div class="menu-variant-toggle" data-menu-variant-toggle>
    <div class="menu-variant-toggle-label">Mobile Menu</div>
    <div class="menu-variant-toggle-buttons">
      <button type="button" class="is-active" data-menu-variant-button data-variant="slide-a6">300ms</button>
      <button type="button" data-menu-variant-button data-variant="slide-a6b">600ms</button>
      <button type="button" data-menu-variant-button data-variant="slide-a6c">1000ms</button>
      <button type="button" data-menu-variant-button data-variant="slide-a6d">加速</button>
      <button type="button" data-menu-variant-button data-variant="slide-a6e">減速</button>
      <button type="button" data-menu-variant-button data-variant="slide-a6f">一斉+末尾</button>
    </div>
  </div>

  <HeroSection {...homeData.hero} />

  <SectionBar num={homeData.why.num} title={homeData.why.title} link={homeData.why.link} />
  <WhySection items={homeData.why.items} />

  <SectionBar num={homeData.experiments.num} title={homeData.experiments.title} link={homeData.experiments.link} />
  <ExperimentsGrid items={homeData.experiments.items} />

  <SectionBar num={homeData.proof.num} title={homeData.proof.title} link={homeData.proof.link} />
  <ProofSection stats={homeData.proof.stats} cases={homeData.proof.cases} />

  <div class="connect-section">
    <SectionBar num={homeData.connect.num} title={homeData.connect.title} dark={true} />
    <ConnectSection cards={homeData.connect.cards} />
  </div>

  <div id="access">
    <SectionBar num={homeData.infra.num} title={homeData.infra.title} link={homeData.infra.link} />
    <InfraSection
      name={homeData.infra.name}
      nameEn={homeData.infra.nameEn}
      photoPlaceholder={homeData.infra.photoPlaceholder}
      table={homeData.infra.table}
      detailHref={homeData.infra.detailHref}
    />
  </div>

  <Footer brandFull={siteData.brandFull} brandDesc={siteData.brandDesc} copyright={siteData.copyright} columns={siteData.footerColumns} />
</Base>

<script>
  function initMenuVariantToggle() {
    const toggle = document.querySelector('[data-menu-variant-toggle]');
    const buttons = Array.from(document.querySelectorAll('[data-menu-variant-button]'));
    const header = document.querySelector('.site-header');
    const menu = document.querySelector('[data-mobile-menu]');
    if (!toggle || !buttons.length || !header || !menu) return;

    const variantClasses = ['mobile-menu--slide-a6', 'mobile-menu--slide-a6b', 'mobile-menu--slide-a6c', 'mobile-menu--slide-a6d', 'mobile-menu--slide-a6e', 'mobile-menu--slide-a6f'];

    function setVariant(variant) {
      header.setAttribute('data-mobile-menu-variant', variant);
      variantClasses.forEach((className) => menu.classList.remove(className));
      menu.classList.add(`mobile-menu--${variant}`);
      buttons.forEach((button) => {
        button.classList.toggle('is-active', button.getAttribute('data-variant') === variant);
      });
      window.localStorage.setItem('ikilab-mobile-menu-variant', variant);
    }

    const initialVariant = window.localStorage.getItem('ikilab-mobile-menu-variant') || 'panel';
    setVariant(initialVariant);

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const variant = button.getAttribute('data-variant');
        if (variant) setVariant(variant);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initMenuVariantToggle);
</script>
