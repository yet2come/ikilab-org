---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionBar from '../components/SectionBar.astro';
import HeroSection from '../components/HeroSection.astro';
import WhySection from '../components/WhySection.astro';
import ExperimentsGrid from '../components/ExperimentsGrid.astro';
import ProofSection from '../components/ProofSection.astro';
import ConnectSection from '../components/ConnectSection.astro';
import InfraSection from '../components/InfraSection.astro';
import { patternA as data } from '../data/pattern-a';
import '../styles/global.css';
---
<Base title="IKILAB — 島内外を接続する実験装置" description="IKILABは、島内外を接続する実験装置です。人口25,000人の壱岐島を舞台に、地域の課題を構造的に解き、新しい接続を生み出します。">
  <Header brand={data.brand} brandHref="/" navItems={data.navItems} contactHref={data.contactHref} />

  <HeroSection {...data.hero} />

  <SectionBar num={data.why.num} title={data.why.title} link={data.why.link} />
  <WhySection items={data.why.items} />

  <SectionBar num={data.experiments.num} title={data.experiments.title} link={data.experiments.link} />
  <ExperimentsGrid items={data.experiments.items} />

  <SectionBar num={data.proof.num} title={data.proof.title} link={data.proof.link} />
  <ProofSection stats={data.proof.stats} cases={data.proof.cases} />

  <div class="connect-section">
    <SectionBar num={data.connect.num} title={data.connect.title} dark={true} />
    <ConnectSection cards={data.connect.cards} />
  </div>

  <SectionBar num={data.infra.num} title={data.infra.title} link={data.infra.link} />
  <InfraSection
    name={data.infra.name}
    nameEn={data.infra.nameEn}
    photoPlaceholder={data.infra.photoPlaceholder}
    table={data.infra.table}
    detailHref={data.infra.detailHref}
  />

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
