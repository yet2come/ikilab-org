---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionBar from '../components/SectionBar.astro';
import HeroSection from '../components/HeroSection.astro';
import WhySection from '../components/WhySection.astro';
import ExperimentsGrid from '../components/ExperimentsGrid.astro';
import ProofSection from '../components/ProofSection.astro';
import ConnectSection from '../components/ConnectSection.astro';
import InfraSection from '../components/InfraSection.astro';
import { homeData } from '../data/home';
import { siteData } from '../data/site';
import '../styles/global.css';
---
<Base title="IKILAB — 島内外を接続する実験装置" description="IKILABは、島内外を接続する実験装置です。人口25,000人の壱岐島を舞台に、地域の課題を構造的に解き、新しい接続を生み出します。">
  <Header brand={siteData.brand} brandHref="/" navItems={siteData.navItems} contactHref={siteData.contactHref} />

  <HeroSection {...homeData.hero} />

  <SectionBar num={homeData.why.num} title={homeData.why.title} link={homeData.why.link} />
  <WhySection items={homeData.why.items} />

  <SectionBar num={homeData.experiments.num} title={homeData.experiments.title} link={homeData.experiments.link} />
  <ExperimentsGrid items={homeData.experiments.items} />

  <SectionBar num={homeData.proof.num} title={homeData.proof.title} link={homeData.proof.link} />
  <ProofSection stats={homeData.proof.stats} cases={homeData.proof.cases} />

  <div class="connect-section">
    <SectionBar num={homeData.connect.num} title={homeData.connect.title} dark={true} />
    <ConnectSection cards={homeData.connect.cards} />
  </div>

  <div id="access">
    <SectionBar num={homeData.infra.num} title={homeData.infra.title} link={homeData.infra.link} />
    <InfraSection
      name={homeData.infra.name}
      nameEn={homeData.infra.nameEn}
      photoPlaceholder={homeData.infra.photoPlaceholder}
      table={homeData.infra.table}
      detailHref={homeData.infra.detailHref}
    />
  </div>

  <Footer brandFull={siteData.brandFull} brandDesc={siteData.brandDesc} copyright={siteData.copyright} columns={siteData.footerColumns} />
</Base>
