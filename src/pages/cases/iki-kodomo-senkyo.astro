---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { patternA as data } from '../../data/pattern-a';
import '../../styles/global.css';

const pageTitle = '壱岐こども選挙 — IKILAB';
const pageDescription = '条例に明記された子どものまちづくり参加の権利を、壱岐市長選と接続した模擬選挙として具体化した事例。背景、設計、実施、学びを整理して紹介します。';

const keyFacts = [
  { label: '実施日', value: '2024年4月14日' },
  { label: '開票日', value: '2024年4月21日' },
  { label: 'こども選挙委員', value: '18名' },
  { label: '大人サポーター', value: '約20名' },
];

const sections = [
  {
    label: 'Background',
    title: 'なぜ、この取り組みが必要だったのか',
    body: [
      '壱岐市自治基本条例第8条には、子どもがまちづくりに参加する権利を有することが明記されています。一方で、実際に子どもが候補者の考えに触れ、自分で考え、選び、地域の意思決定を自分ごととして捉える機会は限られていました。',
      '壱岐こども選挙は、その権利を理念のまま置かず、地域の実践として具体化するために企画しました。選挙を単なる学習対象ではなく、参加の入口として設計したことが、このプロジェクトの出発点です。',
      '加えて、先行事例としての「ちがさきこども選挙」と、そこから立ち上がった全国こども選挙実行委員会の存在が、いきこども選挙の実現に大きく寄与しました。実施ノウハウや制作物、ツール類が積極的に公開されていたことで、壱岐でもゼロから手探りで始めるのではなく、先人の知見を引き継ぎながら地域に合わせて設計することができました。',
    ],
  },
  {
    label: 'Hypothesis',
    title: 'どんな仮説で設計したか',
    body: [
      '候補者に触れ、自分で比較し、投票し、結果を受け止める経験があれば、子どもは地域や政治との関わりを受け身ではなく主体的に捉え始めるのではないか。この仮説をもとに、投票だけでなく「聞く」「考える」「選ぶ」「届ける」までを一連の体験として組み立てました。',
    ],
  },
  {
    label: 'Implementation',
    title: 'どのように実施したか',
    body: [
      '準備は2023年10月から開始し、教育委員会、選挙管理委員会、学校関係者、全国の先行事例に学びながら設計を進めました。実際の壱岐市長選挙と同じ2024年4月14日を投票日に設定し、候補者インタビュー動画の制作、こども選挙委員のワークショップ、投票所運営の準備を段階的に実施しました。',
      '運営体制は、実行委員4名、こども選挙委員18名、小学生から高校生までの参加者、大人サポーター約20名で構成されました。島内には期日前投票所を2か所、当日の投票所を5か所設置し、離島でも成立する実務設計として形にしています。',
      '全国こども選挙実行委員会が掲げる「オープンソース」「自律分散型チーム」「相互扶助ネットワーク」という方針も、実装面で大きな支えになりました。ノウハウや制作物、仕組みを開き、各地域が主体的に運営しながら、困ったときには助けを求め合える前提があったからこそ、壱岐でも現地チーム主導で立ち上げることができました。',
    ],
  },
  {
    label: 'Outcome',
    title: '実施して何が実現したか',
    body: [
      '壱岐こども選挙は、九州で初めて、全国でも7番目のこども選挙として実施されました。条例に記された子どもの参加の権利を、実際の選挙と接続した形で地域に実装できたことは大きな成果です。',
      'また、候補者へのインタビュー、投票所運営、開票までを通じて、子どもが地域の意思決定プロセスに具体的に触れる場をつくることができました。教育、地域、選挙運営が分断されたままでは成立しない取り組みを、協働の枠組みとして成立させられた点にも意味があります。',
    ],
  },
  {
    label: 'Learning',
    title: '見えてきた課題と学び',
    body: [
      '一方で、公職選挙法との距離感、学校現場に負担をかけない告知方法、市民への周知やサポーター募集、日程調整、投票引換券の配布など、制度と運営の両面で課題も明確になりました。期日前投票や投票率目標についても、十分な到達には至っていません。',
      'このプロジェクトを通じて見えたのは、参加の権利を掲げるだけでは参加は起きないということです。参加を支えるためには、制度理解、導線設計、関係者調整、現場運営までを一体で考える必要があります。壱岐という小さな島だからこそ、その設計と改善を地域全体で回せる可能性があることも確認できました。',
    ],
  },
  {
    label: 'Next',
    title: '次につながる視点',
    body: [
      '壱岐こども選挙は、単発のイベントとして完結させるよりも、教育、地域対話、次世代の参加導線とどう接続していくかが次の論点です。IKILABとしては、実験で終わらせず、地域で継続可能な参加の仕組みにどうつなげるかを引き続き探っていきます。',
    ],
  },
];
---
<Base title={pageTitle} description={pageDescription}>
  <Header brand={data.brand} brandHref="/" navItems={data.navItems} contactHref={data.contactHref} />

  <section class="case-hero">
    <div class="case-hero-main">
      <div class="case-hero-tag">Education / Community</div>
      <h1>壱岐こども選挙</h1>
      <div class="hero-en">From participation rights to civic practice.</div>
      <p>
        条例に明記された「子どものまちづくり参加の権利」を、壱岐市長選と接続した模擬選挙として具体化。
        教育と地域参加をつなぐ実践を、半年近い準備期間をかけて実装した事例です。
      </p>
      <div class="case-hero-actions">
        <a href="/cases" class="btn-brutal btn-ghost">一覧に戻る</a>
        <a href="/contact" class="btn-brutal btn-fill">相談する</a>
      </div>
    </div>
    <aside class="case-hero-side">
      <div class="case-fact-label">Key Facts</div>
      {keyFacts.map((fact) => (
        <div class="case-fact-row">
          <span>{fact.label}</span>
          <strong>{fact.value}</strong>
        </div>
      ))}
    </aside>
  </section>

  <section class="case-summary reveal">
    <div class="case-summary-grid">
      <div>
        <div class="case-summary-kicker">Project Summary</div>
        <h2>地域の参加を、制度の外ではなく、制度と接続したかたちで試した。</h2>
      </div>
      <div class="case-summary-points">
        <div class="case-summary-point">
          <span>01</span>
          <p>実際の市長選と同じ日程で投票日を設定し、リアリティのある参加機会をつくった。</p>
        </div>
        <div class="case-summary-point">
          <span>02</span>
          <p>候補者インタビュー、ワークショップ、投票、開票までを一連の学びとして設計した。</p>
        </div>
        <div class="case-summary-point">
          <span>03</span>
          <p>先行地域が公開していたノウハウと相互扶助の仕組みが、壱岐での立ち上げを後押しした。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="case-body">
    {sections.map((section) => (
      <article class="case-section reveal">
        <div class="case-section-label">{section.label}</div>
        <div class="case-section-content">
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </article>
    ))}
  </section>

  <section class="case-timeline reveal">
    <div class="case-timeline-head">
      <div class="case-summary-kicker">Timeline</div>
      <h2>準備から開票までの流れ</h2>
    </div>
    <div class="case-timeline-grid">
      <div class="case-timeline-item">
        <span>2023.10</span>
        <p>先行事例への問い合わせを開始。実施可能性の調査と企画の立ち上げ。</p>
      </div>
      <div class="case-timeline-item">
        <span>2023.11 - 2024.01</span>
        <p>教育委員会、選挙管理委員会、学校関係者への説明と協力依頼を進行。</p>
      </div>
      <div class="case-timeline-item">
        <span>2024.02 - 2024.03</span>
        <p>公開ワークショップ、高校生向け説明会、候補者インタビュー設計、投票所準備を実施。</p>
      </div>
      <div class="case-timeline-item">
        <span>2024.04.10</span>
        <p>候補者の回答動画を公開。</p>
      </div>
      <div class="case-timeline-item">
        <span>2024.04.14</span>
        <p>いきこども選挙の投票日。期日前2か所、当日5か所の投票所を島内に開設。</p>
      </div>
      <div class="case-timeline-item">
        <span>2024.04.21</span>
        <p>第5回ワークショップと開票を実施。結果と学びを整理。</p>
      </div>
    </div>
  </section>

  <section class="case-cta reveal">
    <div>
      <div class="case-summary-kicker">Connect</div>
      <h2>教育、地域参加、実証設計を一緒に考えたい方へ</h2>
      <p>地域での実践を、単発のイベントで終わらせず、検証と運用まで見据えて進めたい方はご相談ください。</p>
      <p class="case-source-note">参考: <a href="https://kodomo-senkyo.com/zenkoku/" target="_blank" rel="noreferrer">全国こども選挙実行委員会の方針</a></p>
    </div>
    <a href="/contact" class="btn-brutal btn-fill">お問い合わせ →</a>
  </section>

  <Footer brandFull={data.brandFull} brandDesc={data.brandDesc} copyright={data.copyright} columns={data.footerColumns} />
</Base>
